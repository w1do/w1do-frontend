# Server-only. Never rename these variables with PUBLIC_, VITE_ or similar.
PLATEGA_BASE_URL=https://app.platega.io
PLATEGA_MERCHANT_ID=replace-with-merchant-id
PLATEGA_SECRET=replace-with-api-secret

# Keep the payout secret separate. Add it only if Payout API is enabled.
PLATEGA_PAYOUT_SECRET=replace-with-separate-payout-secret

# Trusted application URLs. Do not accept them from a browser request.
PLATEGA_RETURN_URL=https://example.com/payment/success
PLATEGA_FAILED_URL=https://example.com/payment/failed

