---
import Layout from "../layouts/Layout.astro";
import Header from "../components/shared/Header.astro";
import Breadcrumbs from "../components/shared/Breadcrumbs.astro";
import Cta from "../components/Cta.astro";
import Footer from "../components/shared/Footer.astro";
import BlogBreadcrumbs from "../components/blog/BlogBreadcrumbs.astro";

const { frontmatter } = Astro.props;

const seoTitle = frontmatter.seo?.title || frontmatter.title;
const seoDescription = frontmatter.seo?.description || frontmatter.description;

const breadcrumbItems = [
    { label: "Главная", href: "/" },
    { label: "Блог", href: "/blog" },
    { label: frontmatter.title, active: true }
];
---

<Layout title={seoTitle} description={seoDescription}>
    <Header/>
    <BlogBreadcrumbs title={frontmatter.title} pubDate={frontmatter.pubDate} />

    <!-- Page Single Post Start -->
    <div class="page-single-post">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <!-- Post Featured Image Start -->
                    {frontmatter.image && (
                        <div class="post-image">
                            <figure class="image-anime reveal">
                                <img src={frontmatter.image} alt={frontmatter.title}>
                            </figure>
                        </div>
                    )}
                    <!-- Post Featured Image Start -->

                    <!-- Post Single Content Start -->
                    <div class="post-content">
                        <!-- Post Entry Start -->
                        <div class="post-entry entry-content">
                            <slot />
                        </div>
                        <!-- Post Entry End -->

                        <!-- Post Tag Links Start -->
                        <div class="post-tag-links">
                            <div class="row align-items-center">
                                <div class="col-lg-8">
                                    <!-- Post Tags Start -->
                                    <div class="post-tags wow fadeInUp" data-wow-delay="0.8s">
                                        <span class="tag-links">
                                            Теги:
                                            {frontmatter.tags ? frontmatter.tags.map((tag, index) => (
                                                <a href="#">{tag}</a>
                                            )) : (
                                                <>
                                                    <a href="#">Искусственный интеллект</a>
                                                    <a href="#">Автоматизация</a>
                                                    <a href="#">Бизнес</a>
                                                </>
                                            )}
                                        </span>
                                    </div>
                                    <!-- Post Tags End -->
                                </div>

                                <div class="col-lg-4">
                                    <!-- Post Social Links Start -->
                                    <div class="post-social-sharing wow fadeInUp" data-wow-delay="0.8s">
                                        <ul>
                                            <li><a href="#"><i class="fa-brands fa-facebook-f"></i></a></li>
                                            <li><a href="#"><i class="fa-brands fa-linkedin-in"></i></a></li>
                                            <li><a href="#"><i class="fa-brands fa-instagram"></i></a></li>
                                            <li><a href="#"><i class="fa-brands fa-x-twitter"></i></a></li>
                                        </ul>
                                    </div>
                                    <!-- Post Social Links End -->
                                </div>
                            </div>
                        </div>
                        <!-- Post Tag Links End -->
                    </div>
                    <!-- Post Single Content End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Page Single Post End -->

    <Cta/>
    <Footer/>
</Layout>

<style>
    .post-content {
        max-width: 100%;
    }
    .btn-white {
        background: var(--white-color) !important;
        color: var(--black-color) !important;
    }
    .btn-white::before {
        background-color: var(--accent-color) !important;
    }
    .btn-white:hover::after {
        background: var(--accent-color) !important;
    }
    .btn-white:hover {
        color: var(--white-color) !important;
    }
    .cta-contact-card {
        margin-top: 30px;
    }
    .btn-default.w-100 {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--black-color) !important;
        border-color: var(--black-color) !important;
        color: var(--white-color) !important;
        padding-right: 24px;
    }
    .btn-default.w-100::before {
        display: none;
    }
    .btn-default.w-100:hover {
        background: var(--accent-color) !important;
        border-color: var(--accent-color) !important;
        color: var(--black-color) !important;
    }

    /* Table Styles */
    .entry-content :global(table) {
        width: 100%;
        margin-bottom: 2rem;
        border-collapse: separate;
        border-spacing: 0;
        border: 1px solid var(--dark-divider-color);
        border-radius: 12px;
        overflow: hidden;
        background-color: var(--accent-secondary-color);
    }

    .entry-content :global(table th) {
        background-color: var(--accent-color);
        color: var(--black-color);
        padding: 15px 20px;
        font-weight: 600;
        text-align: left;
        text-transform: uppercase;
        font-size: 14px;
        letter-spacing: 1px;
    }

    .entry-content :global(table td) {
        padding: 15px 20px;
        border-top: 1px solid var(--dark-divider-color);
        color: var(--text-color);
        line-height: 1.6;
    }

    .entry-content :global(table tr:last-child td) {
        border-bottom: none;
    }

    .entry-content :global(table td:first-child) {
        font-weight: 500;
        color: var(--white-color);
        width: 30%;
    }

    @media (max-width: 767px) {
        .entry-content :global(table) {
            display: block;
            overflow-x: auto;
        }
        .entry-content :global(table td:first-child) {
            width: auto;
        }
    }
</style>