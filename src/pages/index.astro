---
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
import Preloader from "../components/Preloader.astro";
import Header from "../components/shared/Header.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Services from "../components/Services.astro";
import Choose from "../components/Choose.astro";
import IntroVideo from "../components/IntroVideo.astro";
import Feature from "../components/Feature.astro";
import Footer from "../components/shared/Footer.astro";
import Blog from "../components/blog/Blog.astro";
import Faqs from "../components/Faqs.astro";
import Testimonials from "../components/Testimonials.astro";
import Cta from "../components/Cta.astro";
import Process from "../components/Process.astro";
import Projects from "../components/projects/Projects.astro";
import Awards from "../components/Awards.astro";
import Pricing from "../components/Pricing.astro";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout 
	title="Разработчик ИИ: создание нейросетей и внедрение искусственного интеллекта"
	description="Услуги разработчика ИИ (AI Developer). Создание интеллектуальных систем, разработка нейросетей, интеграция LLM и автоматизация бизнеса."
	keywords="разработчик ии, разработка искусственного интеллекта, специалист по ии, ai developer, инженер ии, создание нейросетей, внедрение искусственного интеллекта"
	image="/images/og-main.jpg"
>
	<Header/>
	<Hero 
		title="Разработчик ИИ" 
		description="Я разрабатываю ИИ-решения, создаю нейросети и автоматизирую бизнес. Помогаю компаниям внедрять современные технологии для роста и эффективности."
	/>
	<About 
		subTitle="О разработчике" 
		title="Разработка ИИ"
		description="Как опытный <strong>разработчик ИИ</strong>, я создаю интеллектуальные системы, которые решают реальные задачи бизнеса. Использую передовой стек: <strong>Python</strong>, <strong>TensorFlow</strong>, <strong>PyTorch</strong> и интеграции с <strong>LLM (Claude, GPT-4)</strong> через <strong>Cursor</strong> и <strong>Junie</strong>. Мои решения помогают автоматизировать сложные процессы и извлекать максимум пользы из данных."
		counterTag="Разработанных ИИ-систем"
	/>
	<Services 
		subTitle="Разработка и внедрение ИИ"
		title="Услуги разработчика ИИ"
	/>
	<Pricing 
		subTitle="Цены на разработку"
		title="Стоимость разработки ИИ"
		description="Прозрачное ценообразование, ориентированное на результат. Вы платите за экспертизу и автоматизацию, которая окупается."
		pricingItems={[
			{
				title: "Консультация",
				price: "от 3 000 ₽",
				description: "Разбор ваших задач, подбор стека и формирование AI-roadmap.",
				features: ["Аудит процессов", "Технический план", "Подбор LLM моделей"],
				icon: "/images/icon-pricing-1.svg"
			},
			{
				title: "MVP Решение",
				price: "от 50 000 ₽",
				description: "Создание рабочего прототипа ИИ-сервиса или агента под ключ.",
				features: ["Разработка ядра ИИ", "Интеграция по API", "Базовый интерфейс"],
				icon: "/images/icon-pricing-2.svg"
			},
			{
				title: "Enterprise",
				price: "Индивидуально",
				description: "Сложные экосистемы, RAG и поддержка высоконагруженных систем.",
				features: ["Собственные LLM", "Глубокая интеграция", "SLA поддержка"],
				icon: "/images/icon-pricing-3.svg"
			}
		]}
	/>
	<Awards 
		subTitle="Экспертиза и практика"
		title="Практика разработки систем искусственного интеллекта"
		description="Мой опыт охватывает работу с ведущими языковыми моделями для решения сложных архитектурных и прикладных задач."
		counterValue="100"
		counterDesc="Реализованных ИИ-сценариев и интеграций."
		awards={[
			{
				icon: '/images/llm/gemini-color.svg',
				title: 'LLMOps & RAG',
				description: 'Оптимизация работы с контекстом и базами знаний для точности ответов 99%.',
				year: '2025'
			},
			{
				icon: '/images/llm/claude-color.svg',
				title: 'AI Agents',
				description: 'Разработка автономных систем, способных принимать решения и выполнять действия в API.',
				year: '2025'
			},
			{
				icon: '/images/llm/deepseek-color.svg',
				title: 'Code Generation',
				description: 'Автоматизация написания тестов и документации с помощью кастомных агентов.',
				year: '2026'
			}
		]}
	/>
	<Choose 
		subTitle="Почему я"
		title="Выгоды внедрения ИИ в бизнес"
		description="Я не просто внедряю инструменты, я проектирую системы, которые становятся частью вашей инфраструктуры."
		benefit1Title="Технологический стек"
		benefit1Desc="Использую Python, Node.js и передовые LLM (Claude, GPT, DeepSeek) для создания надежных решений."
		benefit2Title="Скорость и качество"
		benefit2Desc="Связка Cursor + Junie позволяет мне разрабатывать в 5 раз быстрее классического подхода."
		priceTitle="Гибкий бюджет"
		priceDesc="Всегда предлагаю варианты реализации под ваш бюджет, фокусируясь на самом важном функционале."
		priceValue="4 500"
	/>
	<IntroVideo 
		subTitle="Ценность ИИ"
		title="Как разработка ИИ создает ценность для бизнеса"
		tickerItems={["LLM Integration", "AI Agents", "Python", "RAG Systems", "Automation"]}
	/>
	<Feature 
		subTitle="Технологии разработки"
		title="Стек технологий для разработки ИИ-решений"
		description="Я объединяю классическое программирование с мощью современных нейросетей. Связка <strong>Cursor + Claude + Junie</strong> позволяет мне как <strong>разработчику ИИ</strong> создавать и развертывать решения в рекордные сроки."
	/>
	<Projects 
		subTitle="Кейсы"
		title="Проекты ИИ"
		filterAi="Нейросети"
		filterAutomation="AI Агенты"
	/>
	<Process 
		subTitle="Этапы разработки"
		title="Процесс разработки"
		description="Прозрачный процесс разработки с еженедельными демо и фокусом на конечный результат."
		step1Title="Брифинг"
		step1Desc="Обсуждаем задачи и определяем техническую возможность"
		step2Title="Архитектура"
		step2Desc="Выбор моделей, проектирование данных и промптов"
		step3Title="Разработка"
		step3Desc="Итеративное создание системы с тестированием"
		step4Title="Запуск"
		step4Desc="Деплой, обучение сотрудников и поддержка"
	/>
	<Cta 
		subTitle="Начните сейчас"
		title="Нужен опытный разработчик ИИ?"
		description="Обсудите ваш проект напрямую со специалистом. Я помогу составить ТЗ и оценю сроки реализации."
	/>
	<Testimonials 
		subTitle="Кейсы и результаты"
		title="Что говорят клиенты о внедрении ИИ"
		description="Реальные отзывы о том, как мои решения на базе искусственного интеллекта помогают бизнесу расти, экономить время и автоматизировать сложные процессы."
		testimonials={[
			{
				rating: 5,
				text: "Заказывал разработку RAG-системы для техподдержки. Денис внедрил решение, которое теперь отвечает на 80% запросов по нашей документации. Точность ответов поразительная, а нагрузка на живых операторов снизилась в три раза. Очень профессиональный подход.",
				authorName: "Алексей Волков",
				authorRole: "Технический директор SaaS-сервиса",
				authorImage: "/images/author-3.jpg"
			},
			{
				rating: 5,
				text: "Как разработчик ИИ, Денис помог нам автоматизировать анализ юридических документов. То, на что раньше уходило 2 дня работы юриста, теперь ИИ делает за 5 минут. Внедрение окупилось за первый же месяц работы. Рекомендую как сильного эксперта.",
				authorName: "Марина Соколова",
				authorRole: "Основатель юридической фирмы",
				authorImage: "/images/author-4.jpg"
			},
			{
				rating: 5,
				text: "Внедрение ИИ-агентов в наш отдел продаж стало прорывом. Теперь квалификация лидов происходит автоматически через Telegram. Денис спроектировал систему так, что она общается как живой человек и сразу заносит данные в CRM. Скорость обработки выросла на 40%.",
				authorName: "Дмитрий Кравцов",
				authorRole: "CEO рекламного агентства",
				authorImage: "/images/author-1.jpg"
			}
		]}
	/>
	<Faqs 
		subTitle="FAQ"
		title="Что важно знать о разработке с ИИ"
		description="Здесь собраны ответы на ключевые вопросы о том, как строится работа с искусственным интеллектом, какие задачи он решает и чего ожидать от внедрения."
		customFaqs={[
			{
				question: "Что важно знать перед началом разработки с ИИ?",
				answer: "Ключевое — это четкая задача и наличие данных. ИИ эффективен там, где есть повторяющиеся процессы или большие объемы информации. Я помогу определить, принесет ли внедрение нейросети реальный профит вашему бизнесу."
			},
			{
				question: "Какие этапы включает в себя создание ИИ-решения?",
				answer: "Процесс делится на аудит задач, проектирование архитектуры (выбор LLM и метода RAG), разработку промптов и интеграцию в ваши системы. Мы идем итерациями: от прототипа к полнофункциональному агенту."
			},
			{
				question: "Что важно знать о безопасности данных при работе с ИИ?",
				answer: "Ваши данные — ваш актив. Я настраиваю системы так, чтобы информация передавалась по защищенным каналам, а при необходимости развертываю локальные модели (Open Source), которые работают без выхода в интернет."
			},
			{
				question: "Как ИИ помогает экономить бюджет на разработку?",
				answer: "Используя связку Cursor + Claude + Junie, я пишу код и проектирую системы в разы быстрее. Это снижает стоимость разработки для вас, не жертвуя качеством и надежностью продукта."
			},
			{
				question: "Что важно знать о точности и «галлюцинациях» нейросетей?",
				answer: "Для бизнеса критична достоверность. Я использую технологию RAG (Retrieval-Augmented Generation), которая заставляет ИИ отвечать строго по вашей базе знаний, сводя риск ошибок к минимуму."
			},
			{
				question: "Как происходит интеграция ИИ в существующий бизнес?",
				answer: "ИИ встраивается через API в ваши привычные инструменты: CRM, Telegram, Slack или внутренние порталы. Сотрудникам не нужно учить новые программы — они просто общаются с умным помощником."
			},
			{
				question: "Что важно знать о поддержке ИИ после запуска?",
				answer: "Мир ИИ меняется быстро. Я обеспечиваю мониторинг, дообучение модели на новых данных и обновление промптов под меняющиеся задачи бизнеса, чтобы система всегда оставалась актуальной."
			},
			{
				question: "Может ли ИИ полностью заменить моих сотрудников?",
				answer: "ИИ — это не замена, а мощный мультипликатор. Он забирает на себя 80% рутины, позволяя вашим людям сфокусироваться на принятии решений и творческих задачах, которые машина пока не может."
			},
			{
				question: "Что важно знать о сроках окупаемости ИИ-проектов?",
				answer: "Обычно внедрение окупается за 3-6 месяцев за счет сокращения ФОТ на рутинные задачи, ускорения обработки заявок и минимизации человеческого фактора в критических процессах."
			},
			{
				question: "С чего лучше начать: с большого проекта или MVP?",
				answer: "Я всегда рекомендую начинать с MVP (минимально жизнеспособного продукта). Это позволяет за 2-4 недели проверить гипотезу на практике и увидеть первый результат без больших вложений."
			},
			{
				question: "Какие технологии сейчас считаются стандартом в разработке ИИ?",
				answer: "Это Python, использование LangChain для связки компонентов, векторные базы данных для RAG и топовые модели уровня Claude 3.5 Sonnet или GPT-4o для сложной логики."
			},
			{
				question: "Что важно знать о масштабировании ИИ-систем?",
				answer: "Я проектирую архитектуру с запасом. Если сегодня ИИ помогает одному отделу, завтра его можно легко масштабировать на всю компанию, просто добавив новые модули и данные."
			},
			{
				question: "Как ИИ обучается на специфике именно моего бизнеса?",
				answer: "Мы создаем векторное представление вашей документации, регламентов и истории переписок. ИИ не просто «знает всё», он понимает именно ваши бизнес-процессы и терминологию."
			},
			{
				question: "Нужно ли мне нанимать ИИ-специалиста в штат?",
				answer: "На этапе внедрения и поддержки выгоднее работать с внешним экспертом. Я беру на себя всю техническую часть, а вы получаете готовый инструмент, работающий на ваш результат."
			},
			{
				question: "Что важно знать о будущем ИИ в вашей нише?",
				answer: "Те, кто внедряет ИИ сегодня, создают технологический разрыв с конкурентами, который через 1-2 года станет непреодолимым. ИИ становится таким же базовым инструментом, как интернет или Excel."
			}
		]}
	/>
	<Blog/>
	<Footer/>
</Layout>
