---
import { getCollection } from 'astro:content';
import Header from "../components/shared/Header.astro";
import IntroVideo from "../components/IntroVideo.astro";
import Feature from "../components/Feature.astro";
import Faqs from "../components/Faqs.astro";
import Testimonials from "../components/Testimonials.astro";
import Layout from "../layouts/Layout.astro";
import Footer from "../components/shared/Footer.astro";
import Breadcrumbs from "../components/shared/Breadcrumbs.astro";
import ServicesList from "../components/services/ServicesList.astro";
import Projects from "../components/projects/Projects.astro";
import Spacer from "../components/shared/Spacer.astro";
import Pricing from "../components/Pricing.astro";

const entries = await getCollection('services');
const services = entries.map((entry) => ({
    ...entry.data,
    link: `/services/${entry.id}`,
    delay: `${(parseInt(entry.data.no || "0") - 1) * 0.2}s`
})).sort((a, b) => (a.no || "").localeCompare(b.no || ""));
---

<Layout 
    title="Услуги AI автоматизации и разработки | Claude, Cursor"
    description="Заказать автоматизацию бизнес-процессов и разработку ИИ-решений. Используем Claude и Cursor для создания эффективных AI-агентов и MVP."
    keywords="Услуги AI, заказать автоматизацию, разработка ИИ, Claude, Cursor, AI ассистенты, автоматизация бизнеса"
    image="/images/og-services.jpg"
>
    <Header/>
    <Breadcrumbs title="Услуги по внедрению AI В бизнес, Claude, Junie, N8n" breadcrumbItems={[
        {label: "Главная", href: "/"},
        {label: "Заказать услуги по внедрению ИИ", active: true}
    ]}/>
    <Pricing/>
    <ServicesList services={services} isListPage={true} />
    <IntroVideo/>
    <Feature/>
    <Faqs/>
    <Testimonials/>
    <Projects/>
    <Spacer/>
    <Footer/>
</Layout>