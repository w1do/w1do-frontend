---
import Layout from "../layouts/Layout.astro";
import Header from "../components/shared/Header.astro";
import Breadcrumbs from "../components/shared/Breadcrumbs.astro";
import Footer from "../components/shared/Footer.astro";
import ContactForm from "../components/contact/ContactForm.tsx";
---
<Layout 
    title="Контакты | Инженер по AI автоматизации"
    description="Свяжитесь со мной для обсуждения вашего проекта по внедрению ИИ и автоматизации бизнеса. Нахожусь в Тюмени, работаю по всему миру."
    keywords="контакты, заказать AI автоматизацию, Тюмень, разработка ИИ, внедрение нейросетей"
>
    <Header/>
    <Breadcrumbs title="Контакты" breadcrumbItems={[
        {label: "Главная", href: "/"},
        {label: "Контакты", active: true}
    ]}/>
    <!-- Page Contact Us Start -->
    <div class="page-contact-us">
        <div class="container">
            <div class="row">
                <div class="col-xl-12">
                    <!-- Contact Image Form Box Start -->
                    <div class="contact-content-form-box">
                        <!-- Contact Us Content Box Start -->
                        <div class="contact-us-content-box">
                            <!-- Section Title Start -->
                            <div class="section-title">
                                <span class="section-sub-title wow fadeInUp">Связаться со мной</span>
                                <h2 class="text-anime-style-3" data-cursor="-opaque">Давайте воплотим ваши идеи в реальность</h2>
                            </div>
                            <!-- Section Title Start -->

                            <!-- Contact Ticker Box Start -->
                            <div class="contact-ticker-box">
                                <!-- Contact Ticker Content Start -->
                                <div class="contact-ticker-content wow fadeInUp">
                                    <hr>
                                    <p>Технологии которые я использую</p>
                                    <hr>
                                </div>
                                <!-- Contact Ticker Content End -->

                                <!-- Scrolling Ticker Start -->
                                <div class="scrolling-ticker-box">
                                    <div class="scrolling-content">
                                        <span><img src="images/llm/anthropic.svg" alt="Anthropic"></span>
                                        <span><img src="images/llm/openai.svg" alt="OpenAI"></span>
                                        <span><img src="images/llm/claude-color.svg" alt="Claude"></span>
                                        <span><img src="images/llm/gemini-color.svg" alt="Gemini"></span>
                                        <span><img src="images/llm/deepseek-color.svg" alt="DeepSeek"></span>
                                        <span><img src="images/llm/mistral-color.svg" alt="Mistral"></span>
                                        <span><img src="images/llm/n8n-color.svg" alt="n8n"></span>
                                        <span><img src="images/llm/cursor.svg" alt="Cursor"></span>
                                    </div>
                                    <div class="scrolling-content">
                                        <span><img src="images/llm/anthropic.svg" alt="Anthropic"></span>
                                        <span><img src="images/llm/openai.svg" alt="OpenAI"></span>
                                        <span><img src="images/llm/claude-color.svg" alt="Claude"></span>
                                        <span><img src="images/llm/gemini-color.svg" alt="Gemini"></span>
                                        <span><img src="images/llm/deepseek-color.svg" alt="DeepSeek"></span>
                                        <span><img src="images/llm/mistral-color.svg" alt="Mistral"></span>
                                        <span><img src="images/llm/n8n-color.svg" alt="n8n"></span>
                                        <span><img src="images/llm/cursor.svg" alt="Cursor"></span>
                                    </div>
                                </div>
                                <!-- Scrolling Ticker End -->
                            </div>
                            <!-- Contact Ticker Box End -->
                        </div>
                        <!-- Contact Us Content Box End -->

                        <!-- Cta Form Box Start -->
                        <div class="cta-form-box">
                            <div class="section-title section-title-center">
                                <h2 class="text-anime-style-3" data-cursor="-opaque">Оставить заявку</h2>
                            </div>
                            <ContactForm client:load />
                        </div>
                        <!-- Cta Form Box End -->
                    </div>
                    <!-- Contact Image Form Box End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Page Contact Us Start -->


    <!-- Google Map Start -->
    <div class="google-map">
        <div class="container">
            <div class="row section-row">
                <div class="col-lg-12">
                    <!-- Section Title Start -->
                    <div class="section-title section-title-center">
                        <span class="section-sub-title wow fadeInUp">Где я нахожусь</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">Пространство, где рождаются идеи</h2>
                        <p class="wow fadeInUp" data-wow-delay="0.2s">Мое рабочее пространство — это место, где креативность встречается со стратегией, превращая идеи в инновационные цифровые решения, которые приносят реальные результаты.</p>
                    </div>
                    <!-- Section Title End -->
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <!-- Google Map IFrame Start -->
                    <div class="google-map-iframe wow fadeInUp" data-wow-delay="0.4s">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d72373.18683526939!2d65.46087798363385!3d57.1436423402778!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x43bbe269389201f9%3A0x6b3b27f31154563a!2z0KLRjtC80LXQvdGMLCDQotGO0LzQtdC90YHQutCw0Y8g0L7QsdC7Lg!5e0!3m2!1sru!2sru!4v1718265000000!5m2!1sru!2sru"
                                allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                    <!-- Google Map IFrame End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Google Map End -->

    <Footer/>
</Layout>
    <style>
        .scrolling-content img {
            filter: brightness(0) invert(1);
            max-height: 40px;
            width: auto;
            margin: 0 20px;
        }
    </style>