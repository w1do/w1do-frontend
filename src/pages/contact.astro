---
import Layout from "../layouts/Layout.astro";
import Header from "../components/shared/Header.astro";
import Breadcrumbs from "../components/shared/Breadcrumbs.astro";
---
<Layout 
    title="Контакты | Инженер по AI автоматизации"
    description="Свяжитесь со мной для обсуждения вашего проекта по внедрению ИИ и автоматизации бизнеса. Нахожусь в Тюмени, работаю по всему миру."
    keywords="контакты, заказать AI автоматизацию, Тюмень, разработка ИИ, внедрение нейросетей"
>
    <Header/>
    <Breadcrumbs title="Контакты" breadcrumbItems={[
        {label: "Главная", href: "/"},
        {label: "Контакты", active: true}
    ]}/>
    <!-- Page Contact Us Start -->
    <div class="page-contact-us">
        <div class="container">
            <div class="row">
                <div class="col-xl-12">
                    <!-- Contact Image Form Box Start -->
                    <div class="contact-content-form-box">
                        <!-- Contact Us Content Box Start -->
                        <div class="contact-us-content-box">
                            <!-- Section Title Start -->
                            <div class="section-title">
                                <span class="section-sub-title wow fadeInUp">Связаться со мной</span>
                                <h2 class="text-anime-style-3" data-cursor="-opaque">Давайте воплотим ваши идеи в реальность</h2>
                            </div>
                            <!-- Section Title Start -->

                            <!-- Contact Ticker Box Start -->
                            <div class="contact-ticker-box">
                                <!-- Contact Ticker Content Start -->
                                <div class="contact-ticker-content wow fadeInUp">
                                    <hr>
                                    <p>Мои надежные партнеры</p>
                                    <hr>
                                </div>
                                <!-- Contact Ticker Content End -->

                                <!-- Scrolling Ticker Start -->
                                <div class="scrolling-ticker-box">
                                    <div class="scrolling-content">
                                        <span><img src="images/company-logo-1.svg" alt=""></span>
                                        <span><img src="images/company-logo-2.svg" alt=""></span>
                                        <span><img src="images/company-logo-3.svg" alt=""></span>
                                        <span><img src="images/company-logo-4.svg" alt=""></span>
                                        <span><img src="images/company-logo-5.svg" alt=""></span>
                                    </div>
                                    <div class="scrolling-content">
                                        <span><img src="images/company-logo-1.svg" alt=""></span>
                                        <span><img src="images/company-logo-2.svg" alt=""></span>
                                        <span><img src="images/company-logo-3.svg" alt=""></span>
                                        <span><img src="images/company-logo-4.svg" alt=""></span>
                                        <span><img src="images/company-logo-5.svg" alt=""></span>
                                    </div>
                                </div>
                                <!-- Scrolling Ticker End -->
                            </div>
                            <!-- Contact Ticker Box End -->
                        </div>
                        <!-- Contact Us Content Box End -->

                        <!-- Cta Form Box Start -->
                        <div class="cta-form-box">
                            <!-- Section Title Start -->
                            <div class="section-title section-title-center">
                                <h2 class="text-anime-style-3" data-cursor="-opaque">Напишите мне</h2>
                            </div>
                            <!-- Section Title End -->
                            <!-- Cta Form Start -->
                            <div class="contact-form">
                                <form id="contactForm" action="#" method="POST" data-toggle="validator"
                                      class="contact-form wow fadeInUp" data-wow-delay="0.2s">
                                    <div class="row">
                                        <div class="form-group col-md-6 mb-4">
                                            <label>Имя *</label>
                                            <input type="text" name="fname" class="form-control" id="fname"
                                                   placeholder="Введите имя *" required="">
                                            <div class="help-block with-errors"></div>
                                        </div>

                                        <div class="form-group col-md-6 mb-4">
                                            <label>Телефон / Telegram *</label>
                                            <input type="text" name="phone" class="form-control" id="phone"
                                                   placeholder="Введите номер или ник *" required="">
                                            <div class="help-block with-errors"></div>
                                        </div>

                                        <div class="form-group col-md-12 mb-4">
                                            <label>Email *</label>
                                            <input type="email" name="email" class="form-control" id="email"
                                                   placeholder="Введите Email *" required="">
                                            <div class="help-block with-errors"></div>
                                        </div>

                                        <div class="form-group col-md-12 mb-5">
                                            <label>Сообщение *</label>
                                            <textarea name="message" class="form-control" id="message" rows="5"
                                                      placeholder="Ваше сообщение..."></textarea>
                                            <div class="help-block with-errors"></div>
                                        </div>

                                        <div class="col-md-12">
                                            <button type="submit" id="submitBtn" class="btn-default">Отправить сообщение</button>
                                            <div id="msgSubmit" class="h3 hidden"></div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                            <!-- Cta Form End -->
                        </div>
                        <!-- Cta Form Box End -->
                    </div>
                    <!-- Contact Image Form Box End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Page Contact Us Start -->

    <script>
        const contactForm = document.getElementById('contactForm') as HTMLFormElement;
        const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
        const msgSubmit = document.getElementById('msgSubmit');

        if (contactForm) {
            contactForm.addEventListener('submit', async (e) => {
                e.preventDefault();

                const formData = new FormData(contactForm);
                const data = {
                    fname: formData.get('fname'),
                    phone: formData.get('phone'),
                    email: formData.get('email'),
                    message: formData.get('message'),
                };

                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerText = 'Отправка...';
                }

                try {
                    const token = import.meta.env.PUBLIC_TELEGRAM_BOT_TOKEN;
                    const chatId = import.meta.env.PUBLIC_TELEGRAM_CHAT_ID;

                    if (!token || !chatId) {
                        console.error('Telegram Config Missing:', { token: !!token, chatId: !!chatId });
                        throw new Error('Конфигурация Telegram не найдена.');
                    }

                    const text = `🚀 Новое сообщение с контактов!\n\n` +
                                 `👤 Имя: ${data.fname}\n` +
                                 `📞 Связь: ${data.phone}\n` +
                                 `📧 Email: ${data.email}\n` +
                                 `📝 Сообщение: ${data.message}`;

                    const response = await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            chat_id: chatId,
                            text: text,
                            parse_mode: 'HTML'
                        }),
                    });

                    if (response.ok) {
                        if (msgSubmit) {
                            msgSubmit.innerText = 'Сообщение успешно отправлено!';
                            msgSubmit.classList.remove('hidden', 'text-danger');
                            msgSubmit.classList.add('text-success');
                        }
                        contactForm.reset();
                    } else {
                        const errorData = await response.json();
                        throw new Error(`Ошибка Telegram: ${errorData.description || 'Неизвестная ошибка'}`);
                    }
                } catch (error: any) {
                    console.error('Error:', error);
                    if (msgSubmit) {
                        msgSubmit.innerText = error.message || 'Ошибка при отправке.';
                        msgSubmit.classList.remove('hidden', 'text-success');
                        msgSubmit.classList.add('text-danger');
                    }
                } finally {
                    if (submitBtn) {
                        submitBtn.disabled = false;
                        submitBtn.innerText = 'Отправить сообщение';
                    }
                }
            });
        }
    </script>

    <style>
        .hidden {
            display: none;
        }
        .text-success {
            color: #28a745;
            margin-top: 15px;
            font-size: 18px;
        }
        .text-danger {
            color: #dc3545;
            margin-top: 15px;
            font-size: 18px;
        }
    </style>

    <!-- Google Map Start -->
    <div class="google-map">
        <div class="container">
            <div class="row section-row">
                <div class="col-lg-12">
                    <!-- Section Title Start -->
                    <div class="section-title section-title-center">
                        <span class="section-sub-title wow fadeInUp">Где я нахожусь</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">Пространство, где рождаются идеи</h2>
                        <p class="wow fadeInUp" data-wow-delay="0.2s">Мое рабочее пространство — это место, где креативность встречается со стратегией, превращая идеи в инновационные цифровые решения, которые приносят реальные результаты.</p>
                    </div>
                    <!-- Section Title End -->
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <!-- Google Map IFrame Start -->
                    <div class="google-map-iframe wow fadeInUp" data-wow-delay="0.4s">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d72373.18683526939!2d65.46087798363385!3d57.1436423402778!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x43bbe269389201f9%3A0x6b3b27f31154563a!2z0KLRjtC80LXQvdGMLCDQotGO0LzQtdC90YHQutCw0Y8g0L7QsdC7Lg!5e0!3m2!1sru!2sru!4v1718265000000!5m2!1sru!2sru"
                                allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                    <!-- Google Map IFrame End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Google Map End -->
</Layout>