---
import Layout from "../layouts/Layout.astro";
import Header from "../components/shared/Header.astro";
import Breadcrumbs from "../components/shared/Breadcrumbs.astro";
import Preloader from "../components/Preloader.astro";
import About from "../components/About.astro";
import Feature from "../components/Feature.astro";
import Process from "../components/Process.astro";
import Choose from "../components/Choose.astro";
import ConsultationPricing from "../components/consultation/ConsultationPricing.astro";
import ConsultationFaqs from "../components/consultation/ConsultationFaqs.astro";
import Cta from "../components/Cta.astro";
import Footer from "../components/shared/Footer.astro";
import IntroVideo from "../components/IntroVideo.astro";
import Services from "../components/Services.astro";
---

<Layout 
    title="Консультация по внедрению ИИ в бизнес и автоматизации рутины | W1DO"
    description="Я провожу персональные консультации по внедрению ИИ в бизнес и автоматизации рутины. Помогу тебе внедрить Claude, Cursor и n8n для кратного роста продуктивности."
    keywords="консультация по внедрению ии, автоматизация рутины ии, внедрение ии в бизнес, консультация Claude, настройка Cursor, автоматизация разработки"
    image="/images/og-consultation.jpg"
>
    <Header/>
    
    <Breadcrumbs 
        title="Консультация по внедрению ИИ" 
        breadcrumbItems={[
            { label: "Главная", href: "/" },
            { label: "Консультация по ИИ", active: true }
        ]}
    />

    <!-- Описание консультации через компонент About (переиспользуем структуру) -->
    <About 
        subTitle="Консультация по ИИ"
        title="Я помогу тебе внедрить интеллект в бизнес-процессы"
        description="Моя консультация — это самый быстрый способ получить экспертные ответы на вопросы по <strong>внедрению Claude</strong>, <strong>автоматизации рутины</strong> и настройке инструментов. Я разберу твою кодовую базу или бизнес-задачу, составлю <strong>AI Roadmap</strong> и помогу внедрить первые улучшения прямо в ходе сессии."
        counterValue="100"
        counterTag="Часов консультаций"
        counterDescription="экспертиза в решении сложных технических задач"
    />

    <!-- Стек и технологии (Feature) -->
    <Feature 
        subTitle="Автоматизация рутины"
        title="Инструменты для твоей продуктивности"
        description="Я обучаю работе с инструментами, которые сам использую ежедневно: <strong>Claude 3.5 Sonnet</strong> для глубокого анализа, <strong>Cursor</strong> для сверхбыстрой разработки и <strong>n8n</strong> для автоматизации рутинных процессов."
    />

    <!-- Принцип работы / Видео -->
    <IntroVideo 
        subTitle="Как я работаю"
        title="От аудита до внедрения ИИ-агентов"
        tickerItems={["Claude 3.5 Sonnet", "Cursor IDE", "Автоматизация рутины", "Внедрение ИИ"]}
    />

    <!-- Услуги (кратко, что можно обсудить) -->
    <Services 
        subTitle="Темы консультации"
        title="Что я помогу тебе разобрать"
        description="Ниже приведены основные направления, в которых я обладаю глубокой экспертизой и могу помочь твоему проекту или команде уже сегодня."
        limit={3}
    />

    <!-- Процесс консультации -->
    <Process 
        subTitle="Этапы встречи"
        title="Мой план для твоего результата"
        description="Каждая консультация проходит по выверенному алгоритму, что гарантирует максимальную пользу за отведенное время."
        step1Title="Подготовка"
        step1Desc="Я проведу предварительный аудит твоей задачи и кодовой базы"
        step2Title="Разбор"
        step2Desc="Прямой эфир со мной: ответы на вопросы и совместный кодинг"
        step3Title="Артефакты"
        step3Desc="Я передам тебе запись, код, промпты и чек-лист"
        step4Title="Сопровождение"
        step4Desc="Моя короткая поддержка в чате после встречи"
    />

    <!-- Почему выбрать меня -->
    <Choose 
        subTitle="Преимущества"
        title="Почему стоит выбрать меня?"
        description="Я объединяю многолетний опыт в разработке с глубоким пониманием современных LLM. Это позволяет мне давать не просто советы, а рабочие решения."
        benefit1Title="Мой практический опыт"
        benefit1Desc="Все советы я проверил на своих реальных проектах: от стартапов до корпоративных систем."
        benefit2Title="Твоя экономия времени"
        benefit2Desc="Вместо недель изучения документации ты получаешь мои готовые рецепты за один час."
    />

    <!-- Тарифы на консультации (специализированный компонент) -->
    <ConsultationPricing />

    <!-- Ответы на вопросы -->
    <ConsultationFaqs />

    <!-- Призыв к действию -->
    <Cta 
        subTitle="Остались вопросы?"
        title="Нужна индивидуальная программа?"
        description="Если у тебя большая команда или специфический запрос — напиши мне. Я составлю персональный план внедрения ИИ в твою компанию."
        formTitle="Записаться на консультацию"
    />

    <Footer/>
</Layout>