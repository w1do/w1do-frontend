        border: 1px solid var(--dark-divider-color);
        border-radius: 24px;
    }

    .legal-content h2 {
        margin: 12px 0 12px;
        color: var(--white-color);
    }

    .legal-content h3 {
        margin: 34px 0 16px;
        color: var(--white-color);
        font-size: 26px;
    }

    .legal-content p,
    .legal-content li {
        color: var(--text-color);
        font-size: 18px;
        line-height: 1.7em;
    }

    .legal-content p {
        margin-bottom: 18px;
    }

    .legal-content ul {
        margin: 0 0 22px;
        padding-left: 24px;
    }

    .legal-content li {
        margin-bottom: 10px;
    }

    .legal-content a {
        color: var(--accent-color);
        text-decoration: underline;
        text-underline-offset: 4px;
    }

    .legal-updated {
        color: var(--accent-color) !important;
        font-weight: 600;
    }

    @media only screen and (max-width: 767px) {
        .legal-page {
            padding: 50px 0;
        }

        .legal-content {
