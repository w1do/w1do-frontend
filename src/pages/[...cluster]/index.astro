---
import { getCollection } from 'astro:content';
import LandingClusterLayout from '../../layouts/LandingClusterLayout.astro';

export async function getStaticPaths() {
  const hubs = await getCollection('landingCluster', ({ data }) => data.hub === true);
  const spokes = await getCollection('landingSpoke');

  const uniqueByUrl = (items) => {
    const urls = new Set();
    return items.filter((item) => {
      const normalizedUrl = item.url.replace(/\/$/, '');
      if (urls.has(normalizedUrl)) {
        return false;
      }
      urls.add(normalizedUrl);
      return true;
    });
  };
  
  return hubs.map((pillar) => {
    const pillarSpokes = spokes
      .filter(({ data }) => data.cluster === pillar.id)
      .map((entry) => ({
        title: entry.data.title,
        description: entry.data.description,
        excerpt: entry.data.excerpt,
        order: entry.data.order,
        url: `/${pillar.id}/${entry.id.split('/').pop()}`,
      }));

    const childHubs = hubs
      .filter(({ data }) => data.cluster === pillar.id)
      .map((entry) => ({
        title: entry.data.title,
        description: entry.data.description,
        excerpt: entry.data.description,
        order: entry.data.order,
        url: `/${entry.id}`,
      }));

    return {
      params: { cluster: pillar.id },
      props: {
        pillar,
        spokes: uniqueByUrl([...childHubs, ...pillarSpokes]).sort((a, b) => a.order - b.order),
      },
    };
  });
}

const { pillar, spokes } = Astro.props;
---

<LandingClusterLayout frontmatter={pillar.data} spokes={spokes} />
