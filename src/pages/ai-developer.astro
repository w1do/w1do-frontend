---
import Layout from "../layouts/Layout.astro";
import Header from "../components/shared/Header.astro";
import Breadcrumbs from "../components/shared/Breadcrumbs.astro";
import About from "../components/About.astro";
import Feature from "../components/Feature.astro";
import Process from "../components/Process.astro";
import Choose from "../components/Choose.astro";
import HirePricing from "../components/hire/HirePricing.astro";
import HireFaqs from "../components/hire/HireFaqs.astro";
import Services from "../components/Services.astro";
import Cta from "../components/Cta.astro";
import Footer from "../components/shared/Footer.astro";
import IntroVideo from "../components/IntroVideo.astro";
import Projects from "../components/projects/Projects.astro";
import Spacer from "../components/shared/Spacer.astro";

---

<Layout 
    title="Разработчик ИИ, Вайб кодер и MLOps инженер | W1DO"
    description="Я — профессиональный разработчик ИИ, Вайб кодер и MLOps инженер. Создаю автономных агентов, внедряю RAG-системы и настраиваю LLMOps пайплайны для бизнеса."
    keywords="Вайб кодер, MLOps инженер, разработчик ИИ, AI developer, создание AI агентов, RAG системы, автоматизация n8n, LLMOps"
>
    <Header/>
    
    <Breadcrumbs 
        title="Разработчик ИИ, MLOps и Вайб кодинг" 
        breadcrumbItems={[
            { label: "Главная", href: "/" },
            { label: "ИИ-разработчик", active: true }
        ]}
    />

    <About 
        subTitle="Vibe Coder & MLOps"
        title="Я создаю интеллект для твоего бизнеса"
        description="Я помогаю компаниям внедрять ИИ не как игрушку, а как ядро системы. Мой подход — это <strong>вайб кодинг (vibe coding)</strong>: быстрая и точная разработка через синергию с LLM. Я специализируюсь на <strong>MLOps</strong>, проектировании <strong>сложных оркестраций</strong> и создании масштабируемых <strong>workflow в n8n</strong>. Я строю системы, которые реально работают."
        counterValue="15"
        counterTag="Спроектированных систем"
        counterDescription="от сложных RAG-решений до автономных агентных циклов"
    />

    <Feature 
        subTitle="Мой технологический стек"
        title="Архитектура и Вайб"
        description="Я строю решения, используя современные подходы: <strong>агентные циклы (agent loop)</strong>, <strong>tool calling</strong> и эффективные <strong>RAG-системы</strong>. Как <strong>Вайб кодер</strong>, я использую возможности ИИ для ускорения разработки в разы, не теряя в качестве <strong>MLOps</strong> инфраструктуры."
    />

    <IntroVideo 
        subTitle="Экспертиза в AI"
        title="От вайб-прототипа до промышленного MLOps"
        tickerItems={["RAG Systems", "Vibe Coding", "n8n Automation", "MLOps", "AI Agents"]}
    />

    <div class="bg-section">
        <Services 
            subTitle="Сценарии применения"
            title="Задачи, которые я решаю"
            description="Я фокусируюсь на создании интеллектуальных ассистентов, систем классификации данных и автоматизации процессов через ИИ."
            limit={3}
        />
    </div>

    <div class="bg-section">
        <Process 
            subTitle="Как я работаю"
            title="От идеи до внедрения MLOps"
            description="Мой процесс разработки строится на итеративном подходе и глубоком понимании бизнес-потребностей."
            step1Title="Анализ и Вайб"
            step1Desc="Я идентифицирую сценарии, где ИИ даст максимальный буст, и быстро создаю первый прототип"
            step2Title="Проектирование"
            step2Desc="Разработка архитектуры: API, GraphQL, очереди и потоки данных под будущий MLOps"
            step3Title="Реализация"
            step3Desc="Я собираю workflow в n8n, настраиваю агентов и внедряю RAG-системы в твой ландшафт"
            step4Title="MLOps и Качество"
            step4Desc="Внедрение метрик качества, мониторинга и автоматического дообучения твоих ИИ-решений"
        />
    </div>

    <Choose 
        subTitle="Компетенции"
        title="Почему я?"
        description="Я сочетаю техническую глубину в ИИ с пониманием бизнес-процессов и современными методологиями быстрой разработки."
        benefit1Title="Вайб кодинг"
        benefit1Desc="Я работаю в связке с топовыми LLM, что позволяет мне выдавать результат в 5-10 раз быстрее обычных разработчиков."
        benefit2Title="MLOps экспертиза"
        benefit2Desc="Я знаю, как вывести ИИ-модель в продакшн так, чтобы она работала стабильно и предсказуемо."
    />

    <HirePricing />

    <HireFaqs />
    
    <Spacer height="120px" />

    <Projects />

    <Spacer height="120px" />

    <Cta 
        subTitle="Готовы усилить команду?"
        title="Давайте обсудим ваши задачи по внедрению ИИ"
        description="Если вы ищете разработчика, который понимает разницу между 'просто промптом' и промышленным ИИ-решением — напишите мне."
        formTitle="Обсудить сотрудничество"
    />

    <Footer/>
</Layout>
