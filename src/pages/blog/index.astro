---
import { getCollection } from 'astro:content';
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/shared/Header.astro";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import BlogList from "../../components/blog/BlogList.astro";
import Cta from "../../components/Cta.astro";
import Footer from "../../components/shared/Footer.astro";

const POSTS_PER_PAGE = 10;

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalPages = Math.max(1, Math.ceil(sortedPosts.length / POSTS_PER_PAGE));
const pagePosts = sortedPosts.slice(0, POSTS_PER_PAGE);

const breadcrumbItems = [
    { label: "Главная", href: "/" },
    { label: "Блог", active: true }
];
---

<Layout title="Блог | ИИ в бизнесе и автоматизация" description="Статьи об искусственном интеллекте, автоматизации бизнес-процессов и цифровом маркетинге.">
    <Header/>
    <Breadcrumbs title="Наш Блог" breadcrumbItems={breadcrumbItems} />
    <BlogList posts={pagePosts} currentPage={1} totalPages={totalPages} />
    <Cta/>
    <Footer/>
</Layout>