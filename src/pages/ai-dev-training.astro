---
import Layout from "../layouts/Layout.astro";
import Header from "../components/shared/Header.astro";
import Breadcrumbs from "../components/shared/Breadcrumbs.astro";
import About from "../components/About.astro";
import Feature from "../components/Feature.astro";
import Process from "../components/Process.astro";
import Choose from "../components/Choose.astro";
import Services from "../components/Services.astro";
import Cta from "../components/Cta.astro";
import Footer from "../components/shared/Footer.astro";
import IntroVideo from "../components/IntroVideo.astro";
import Spacer from "../components/shared/Spacer.astro";
import HireFaqs from "../components/hire/HireFaqs.astro";
import TrainingPricing from "../components/training/TrainingPricing.astro";

---

<Layout 
    title="Обучение ИИ: стать инженером искусственного интеллекта | W1DO"
    description="Практическое обучение ИИ: от основ Claude до проектирования RAG-систем и MCP-серверов. Курсы по искусственному интеллекту для разработчиков от эксперта."
    keywords="обучение ИИ, инженер искусственного интеллекта обучение, курсы по обучению искусственному интеллекту, специалист по обучению ИИ, обучение Claude, разработка RAG агентов, настройка MCP"
>
    <Header/>
    
    <Breadcrumbs 
        title="Обучение ИИ и разработке агентов" 
        breadcrumbItems={[
            { label: "Главная", href: "/" },
            { label: "Обучение ИИ", active: true }
        ]}
    />

    <About 
        subTitle="Инженер искусственного интеллекта"
        title="Я обучу тебя проектировать системы будущего"
        description="Я обучаю не просто писать промпты, а проектировать <strong>промышленные ИИ-системы</strong>. Я передаю свой опыт настройки <strong>Model Context Protocol (MCP)</strong>, создания автономных <strong>RAG-агентов</strong> и сложных систем <strong>оркестрации LLM</strong>. Моё обучение — это путь к профессии инженера искусственного интеллекта через реальную практику."
        counterValue="100"
        counterTag="Часов практики"
        counterDescription="интенсивного погружения в архитектуру агентных систем"
    />

    <Feature 
        subTitle="Программа обучения ИИ"
        title="От идеи до работающего ИИ-продукта"
        description="Я разберу с тобой полный цикл создания ИИ-сервисов: работу с <strong>Context Window</strong>, внедрение <strong>Knowledge Graph</strong>, настройку <strong>MCP-серверов</strong> и построение отказоустойчивых <strong>Workflow</strong>. Ты научишься тому, что действительно нужно на рынке."
    />

    <IntroVideo 
        subTitle="Курсы по обучению искусственному интеллекту"
        title="Технологии, которые я помогу тебе освоить"
        tickerItems={["Claude 3.5 Sonnet", "RAG Architecture", "MCP Setup", "AI Orchestration", "Agentic Workflows"]}
    />

    <div class="bg-section">
        <Services 
            subTitle="Специалист по обучению ИИ"
            title="Направления моей программы"
            description="Каждый модуль я разработал на основе реальных коммерческих кейсов, которые я сам реализовал для бизнеса."
            limit={6}
        />
    </div>

    <div class="bg-section">
        <Process 
            subTitle="Как проходит обучение ИИ"
            title="Твой путь до AI-архитектора"
            description="Моя пошаговая методика освоения инструментов разработки ИИ-решений."
            step1Title="Основы и Claude"
            step1Desc="Глубокое погружение в возможности Claude, системные промпты и эффективное управление контекстом"
            step2Title="RAG и Память"
            step2Desc="Я научу тебя строить системы векторного поиска и работать с долгосрочной памятью агентов"
            step3Title="MCP и Инструменты"
            step3Desc="Настройка Model Context Protocol для связи LLM с данными и API через мои проверенные паттерны"
            step4Title="Оркестрация"
            step4Desc="Создание сложных агентных циклов и продакшн-реди пайплайнов для реальных задач"
        />
    </div>

    <Choose 
        subTitle="Почему стоит учиться у меня?"
        title="Мой практический опыт вместо сухой теории"
        description="Я делюсь наработками, полученными при создании реальных коммерческих систем. Я не просто теоретик, я практик, который ежедневно внедряет ИИ."
        benefit1Title="Актуальный стек"
        benefit1Desc="Я использую только самые свежие инструменты: Claude, новейшие MCP-коннекторы и библиотеки оркестрации."
        benefit2Title="Проектный подход"
        benefit2Desc="В конце обучения у тебя будет работающий прототип системы, который я помогу довести до готовности."
    />

    <TrainingPricing />

    <HireFaqs />
    
    <Spacer height="120px" />

    <Cta 
        subTitle="Готовы начать?"
        title="Давайте построим ваш следующий AI-проект вместе"
        description="Оставьте заявку на консультацию или обучение. Разберем ваши задачи и составим индивидуальный план внедрения ИИ."
        formTitle="Начать обучение"
    />

    <Spacer height="120px" />

    <Footer/>
</Layout>
