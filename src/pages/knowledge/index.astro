---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/shared/Header.astro";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import FaqItem from "../../components/shared/faq/FaqItem.astro";
import FaqSection from "../../components/shared/faq/FaqSection.astro";
import FaqPageContent from "../../components/shared/faq/FaqPageContent.astro";
import Footer from "../../components/shared/Footer.astro";
import Cta from "../../components/Cta.astro";

const categories = [
    { label: "ИИ Агенты и LLM", href: "#faq_agents" },
    { label: "Автоматизация Бизнеса", href: "#faq_business" },
    { label: "Аналитика и Excel", href: "#faq_excel" },
    { label: "Инструменты и Технологии", href: "#faq_tools" },
    { label: "Как мы работаем", href: "#faq_process" },
    { label: "Стоимость и Процессы", href: "#faq_pricing" },
    { label: "Разработка и Боты", href: "#faq_dev" },
];
---
<Layout 
    title="База знаний по RAG, LLM и разработке с помощью AI (Claude) | W1DO"
    description="Узнайте всё о внедрении RAG, использовании LLM (Claude, Gemini) и автоматизации бизнеса с помощью ИИ-агентов. Ответы на технические и бизнес вопросы."
    keywords="RAG, LLM, разработка AI, Claude, ИИ агенты, база знаний ИИ, автоматизация бизнеса, внедрение ИИ"
>
    <Header />
    <Breadcrumbs title="База знаний: RAG, LLM и ИИ-разработка" breadcrumbItems={[
        {label: "Главная", href: "/"},
        {label: "База знаний по AI и Claude", active: true}
    ]}/>

    <!-- Page Faqs Start -->
    <FaqPageContent categories={categories}>
        <FaqSection id="faq_agents" title="ИИ Агенты и LLM">
                            <FaqItem 
                                id="1" 
                                active={true}
                                question="1. Кто такой разработчик LLM и чем он занимается?" 
                                answer="<p>Разработчик LLM (Large Language Models) проектирует и внедряет системы на базе больших языковых моделей, таких как Claude и Gemini. Мы занимаемся настройкой RAG (Retrieval-Augmented Generation), интеграцией моделей в бизнес-процессы и созданием автономных ИИ-агентов.</p>" 
                            />
                            <FaqItem 
                                id="2" 
                                delay="0.2s"
                                question="2. Что такое RAG и зачем это нужно моему бизнесу?" 
                                answer="<p>RAG (Retrieval-Augmented Generation) — это технология, которая позволяет ИИ использовать ваши собственные данные (документы, базу знаний, CRM) для ответов. Это исключает галлюцинации ИИ и делает ответы точными и актуальными именно для вашей компании.</p>" 
                            />
                            <FaqItem 
                                id="3" 
                                delay="0.4s"
                                question="3. Кто такой ИИ-агент и чем он отличается от обычного чат-бота?" 
                                answer="<p>ИИ-агент — это автономная система, которая не просто отвечает на вопросы, но и выполняет действия: планирует задачи, использует инструменты (API, поиск, расчеты) и стремится к достижению поставленной цели. Например, ИИ-агент для Авито может сам вести диалог, уточнять детали и закрывать сделку.</p>" 
                            />
                            <FaqItem 
                                id="4" 
                                delay="0.6s"
                                question="4. Какие ИИ-агенты доступны в России?" 
                                answer="<p>Мы разрабатываем решения на базе моделей Claude и Gemini, которые доступны через API. Также мы используем локальные LLM для обеспечения безопасности данных. Наши агенты адаптированы под российский рынок и популярные сервисы (Авито, Telegram, Битрикс24).</p>" 
                            />
                        </FaqSection>

                        <FaqSection id="faq_business" title="Автоматизация Бизнеса">
                            <FaqItem 
                                id="6" 
                                active={true}
                                parentId="accordion_faq_business"
                                question="1. Как использовать ИИ в продажах и маркетинге?" 
                                answer="<p>ИИ может автоматизировать квалификацию лидов, создание персонализированных предложений и обработку возражений. ИИ-агент маркетолог помогает с генерацией контента, анализом конкурентов и оптимизацией рекламных кампаний в реальном времени.</p>" 
                            />
                            <FaqItem 
                                id="7" 
                                delay="0.2s"
                                parentId="accordion_faq_business"
                                question="2. Заменит ли ИИ менеджеров по продажам?" 
                                answer="<p>ИИ не заменяет людей, а освобождает их от рутины. Он берет на себя 80% типовых диалогов и первичную обработку, позволяя менеджерам сосредоточиться на сложных сделках и выстраивании отношений.</p>" 
                            />
                            <FaqItem 
                                id="8" 
                                delay="0.4s"
                                parentId="accordion_faq_business"
                                question="3. Как реализовать автоответчик на Авито с помощью ИИ?" 
                                answer="<p>Мы создаем специализированных ИИ-агентов для Авито, которые мгновенно отвечают на запросы покупателей, учитывают наличие товара из вашей базы и могут даже записывать клиента на услугу, работая 24/7 без выходных.</p>" 
                            />
                            <FaqItem 
                                id="9" 
                                delay="0.6s"
                                parentId="accordion_faq_business"
                                question="4. Как зарабатывать на ИИ‑агентах в бизнесе?" 
                                answer="<p>Классические сценарии монетизации: рост конверсии лидов, up‑/cross‑sell, сокращение SLA поддержки, автоматизация рутины. Мы считаем ROI до старта и настраиваем метрики в дашбордах.</p>" 
                            />
                        </FaqSection>

                        <FaqSection id="faq_tools" title="Инструменты и Технологии">
                            <FaqItem 
                                id="11" 
                                active={true}
                                parentId="accordion_faq_tools"
                                question="1. Какие инструменты разработки вы используете?" 
                                answer="<p>Наш стек включает передовые модели Claude и Gemini, а также специализированные инструменты разработки, такие как Junie. Для веб-интерфейсов мы используем Astro и Tailwind CSS, а для сложных интеграций — Python и Web API.</p>" 
                            />
                            <FaqItem 
                                id="12" 
                                delay="0.2s"
                                parentId="accordion_faq_tools"
                                question="2. Что такое Web API и зачем оно нужно для ИИ?" 
                                answer="<p>Web API — это интерфейс, который позволяет ИИ обмениваться данными с вашим сайтом, CRM или другими сервисами. С помощью Web API мы интегрируем &quot;мозг&quot; ИИ в вашу существующую цифровую инфраструктуру.</p>" 
                            />
                            <FaqItem 
                                id="13" 
                                delay="0.4s"
                                parentId="accordion_faq_tools"
                                question="3. Как создаются дашборды для аналитики данных?" 
                                answer="<p>Мы помогаем создавать дашборды как в Excel, так и в современных веб-интерфейсах. ИИ помогает автоматизировать сбор данных из разных источников и визуализировать ключевые показатели бизнеса для принятия решений.</p>" 
                            />
                            <FaqItem 
                                id="14" 
                                delay="0.6s"
                                parentId="accordion_faq_tools"
                                question="4. SaaS и PaaS: что выбрать для ИИ-решения?" 
                                answer="<p>SaaS — готовый сервис по подписке; PaaS — платформа для разработки и размещения своих приложений. Мы поможем выбрать модель в зависимости от требований к кастомизации, безопасности и стоимости владения.</p>" 
                            />
                            <FaqItem 
                                id="15" 
                                delay="0.8s"
                                parentId="accordion_faq_tools"
                                question="5. Инструменты веб‑разработчика: что используем для сайтов и Web API?" 
                                answer="<p>Инструменты для разработки веб‑сайтов: Astro, Tailwind, shadcn/ui, Lucide. Веб‑инструменты: REST/Web API, Directus CMS, интеграции с CRM. Для разработчика ИИ — Python, LangChain, векторные БД и RAG.</p>" 
                            />
                            <FaqItem 
                                id="15b" 
                                delay="1.0s"
                                parentId="accordion_faq_tools"
                                question="6. MAX мессенджер: сквозное шифрование и боты" 
                                answer="<p>Используем корпоративные мессенджеры с E2E‑шифрованием, такие как MAX, для приватных сценариев. Возможна разработка ботов и интеграция ИИ‑агентов с безопасной обработкой данных.</p>" 
                            />
                        </FaqSection>

                        <FaqSection id="faq_pricing" title="Стоимость и Процессы">
                            <FaqItem 
                                id="16" 
                                active={true}
                                parentId="accordion_faq_pricing"
                                question="1. Сколько стоит создание ИИ-агента?" 
                                answer="<p>Стоимость разработки ИИ-агента зависит от сложности задач, количества интеграций и используемых моделей. Мы предлагаем гибкие варианты: от простых автоответчиков до сложных многошаговых агентов с глубокой интеграцией в бизнес.</p>" 
                            />
                            <FaqItem 
                                id="17" 
                                delay="0.2s"
                                parentId="accordion_faq_pricing"
                                question="2. Как начать работу над проектом автоматизации?" 
                                answer="<p>Наш процесс включает аудит ваших текущих задач, разработку стратегии внедрения ИИ, создание прототипа и полноценный запуск системы с последующим обучением сотрудников.</p>" 
                            />
                            <FaqItem 
                                id="18" 
                                delay="0.4s"
                                parentId="accordion_faq_pricing"
                                question="3. Сколько стоит чат‑бот/бот‑автоответчик для Авито и Telegram?" 
                                answer="<p>Стоимость зависит от логики, каналов (Авито, Telegram), интеграций (CRM, база остатков) и нагрузки. Предложим пакет: разработка + включенный лимит запросов к ИИ, с прозрачной тарификацией по токенам.</p>" 
                            />
                        </FaqSection>

                        <FaqSection id="faq_excel" title="Аналитика и Excel">
                            <FaqItem 
                                id="excel1" 
                                active={true}
                                parentId="accordion_faq_excel"
                                question="1. Как создать дашборд в Excel с нуля (пошаговая инструкция)?" 
                                answer="<p>Шаги: 1) Сбор данных (CSV, 1С, CRM). 2) Очистка и структурирование. 3) Создание сводных таблиц. 4) Построение графиков и KPI. 5) Настройка слайсеров/фильтров. 6) Публикация и автообновление. Мы можем подключить ИИ для автоматической подготовки данных и рекомендаций по визуализации.</p>" 
                            />
                            <FaqItem 
                                id="excel2" 
                                delay="0.2s"
                                parentId="accordion_faq_excel"
                                question="2. Визуализация данных в Excel и дашборд: что это и как сделать?" 
                                answer="<p>Дашборд в Excel — это набор визуализаций (графики, карты, KPI), связанных со сводными таблицами. Мы проектируем UX-дизайн дашборда и автоматизируем сбор данных, чтобы ваш «эксель дашборд» всегда был актуален.</p>" 
                            />
                            <FaqItem 
                                id="excel3" 
                                delay="0.4s"
                                parentId="accordion_faq_excel"
                                question="3. Как сделать дашборд по сводной таблице в Excel?" 
                                answer="<p>Создайте сводную таблицу по очищенным данным, добавьте слайсеры для фильтрации и постройте графики на её основе. При необходимости подключим Power Query/Power Pivot и источники из облака.</p>" 
                            />
                            <FaqItem 
                                id="excel4" 
                                delay="0.6s"
                                parentId="accordion_faq_excel"
                                question="4. Обучение дашбордам в Excel: с чего начать?" 
                                answer="<p>Мы проводим обучение: от базовых сводных таблиц до продвинутой визуализации и автоматизации обновлений. Даем шаблоны, чек-листы и записываем видеоинструкции под ваш кейс.</p>" 
                            />
                        </FaqSection>

                        <FaqSection id="faq_process" title="Как мы работаем">
                            <FaqItem 
                                id="proc1" 
                                active={true}
                                parentId="accordion_faq_process"
                                question="1. Этапы внедрения ИИ в бизнес: аудит → стратегія → прототип → запуск → обучение → поддержка" 
                                answer="<p>На старте проводим аудит задач и данных, формируем ТЗ и KPI. Далее создаем прототип (PoC), интегрируем через Web API/CRM, обучаем команду и сопровождаем решение. Используем модели Claude, Gemini и инструменты Junie.</p>" 
                            />
                            <FaqItem 
                                id="proc2" 
                                delay="0.2s"
                                parentId="accordion_faq_process"
                                question="2. Безопасность и приватность данных при ИИ и RAG" 
                                answer="<p>Используем RAG, хранение эмбеддингов в вашем контуре, шифрование. Возможна работа с локальными LLM и корпоративными мессенджерами. Доступы разграничены, аудит запросов и логирование по GDPR/152-ФЗ.</p>" 
                            />
                            <FaqItem 
                                id="proc3" 
                                delay="0.4s"
                                parentId="accordion_faq_process"
                                question="3. Какие инструменты мы используем: Claude, Gemini, Junie, Astro, Tailwind, Python" 
                                answer="<p>Модели: Claude, Gemini, а также локальные LLM. Инженерия: Junie. Веб: Astro, Tailwind. Бэкенд и интеграции: Python, Web API, Directus CMS. Выбираем стек по целям и ограничениям проекта.</p>" 
                            />
                        </FaqSection>

                        <FaqSection id="faq_dev" title="Разработка и Боты">
                            <FaqItem 
                                id="21" 
                                active={true}
                                parentId="accordion_faq_dev"
                                question="1. На каком языке программирования пишут ботов для Telegram?" 
                                answer="<p>Мы используем Python как основной язык для разработки ботов и ИИ-агентов. Он обладает мощными библиотеками (aiogram, pytelegrambotapi) и лучшей экосистемой для работы с ИИ и LLM.</p>" 
                            />
                            <FaqItem 
                                id="22" 
                                delay="0.2s"
                                parentId="accordion_faq_dev"
                                question="2. Что лучше: aiogram или pytelegrambotapi?" 
                                answer="<p>Для профессиональной разработки мы предпочитаем aiogram. Это асинхронная библиотека, которая позволяет боту обрабатывать тысячи запросов одновременно без задержек, что критично для высоконагруженных ИИ-агентов.</p>" 
                            />
                            <FaqItem 
                                id="23" 
                                delay="0.4s"
                                parentId="accordion_faq_dev"
                                question="3. Как сделать аукцион в Telegram?" 
                                answer="<p>Мы разрабатываем специализированных ботов для проведения аукционов в Telegram. Бот автоматически принимает ставки, следит за временем, уведомляет участников и фиксирует победителя, исключая человеческий фактор и ошибки.</p>" 
                            />
                            <FaqItem 
                                id="24" 
                                delay="0.6s"
                                parentId="accordion_faq_dev"
                                question="4. Есть ли на Авито боты и как включить автоответ?" 
                                answer="<p>Стандартные автоответы ограничены. Мы делаем ИИ‑ботов для Авито: отвечают по базе товаров/услуг, уточняют детали и ведут к продаже. Подключим к API и настроим умные скрипты общения.</p>" 
                            />
                            <FaqItem 
                                id="25" 
                                delay="0.8s"
                                parentId="accordion_faq_dev"
                                question="5. Бот для участия в торгах и тендерах: что умеет?" 
                                answer="<p>Бот контролирует сроки, подготавливает документы, напоминает о шагах и автоматически подает заявки по регламенту площадки. Возможна интеграция с календарями и CRM.</p>" 
                            />
                        </FaqSection>

                        <!-- Дополнительные вопросы по LLM и RAG -->
                        <FaqSection id="faq_extra" title="LLM и RAG — частые вопросы">
                            <FaqItem 
                                id="31" 
                                active={true}
                                parentId="accordion_faq_extra"
                                question="1. LLM и RAG: что это и как работает вместе?" 
                                answer="<p>LLM (большие языковые модели) генерируют ответы, RAG подключает к ним вашу базу знаний. Так мы получаем точные ответы без галлюцинаций, актуальные именно для вашего бизнеса.</p>" 
                            />
                            <FaqItem 
                                id="32" 
                                delay="0.2s"
                                parentId="accordion_faq_extra"
                                question="2. LLM-агенты: что это такое?" 
                                answer="<p>LLM-агенты — автономные «сотрудники», которые планируют шаги, вызывают инструменты (поиск, API), помнят контекст и достигают цели. Примеры: ИИ агент маркетолог, ИИ агент для Авито, агент поддержки 24/7.</p>" 
                            />
                            <FaqItem 
                                id="33" 
                                delay="0.4s"
                                parentId="accordion_faq_extra"
                                question="3. «Безлимитный» ИИ-агент: возможен ли фикс-прайс?" 
                                answer="<p>Модели тарифицируются по токенам, поэтому «безлимит» невозможен. Но мы предлагаем тарифы с включенным объёмом запросов и оптимизацию промптов, кеширование и RAG, чтобы стоимость была предсказуемой.</p>" 
                            />
                        </FaqSection>

    </FaqPageContent>
    <!-- Page Faqs End -->

    <Cta/>

    <Footer/>
</Layout>