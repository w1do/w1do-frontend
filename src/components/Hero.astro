---
import { Image } from 'astro:assets';
---
<!-- Hero Section Start -->
<div class="hero-prime">
    <!-- Video Start -->
    <div class="hero-bg-video-prime">
        <!-- Selfhosted Video Start -->
        <!-- <video autoplay muted loop id="herovideo"><source src="/images/hero-bg-video.mp4" type="video/mp4"></video> -->
        <video autoplay="" muted="" playsinline="" loop="" id="myvideo" preload="metadata"><source src="/videos/fexora-hero-video-prime.mp4" type="video/mp4"></video>
        <!-- Selfhosted Video End -->

        <!-- Youtube Video Start -->
        <!-- <div id="herovideo" class="player" data-property="{videoURL:'OjTRVpgtcG4',containment:'.hero-video', showControls:false, autoPlay:true, loop:true, vol:0, mute:false, startAt:0,  stopAt:296, opacity:1, addRaster:true, quality:'large', optimizeDisplay:true}"></div> -->
        <!-- Youtube Video End -->
    </div>
    <!-- Video End -->

    <div class="container">
        <div class="row">
            <div class="col-xl-12">
                <!-- Hero Content Box Start -->
                <div class="hero-content-box-prime">
                    <!-- Hero Sub Heading Start -->
                    <div class="hero-sub-heading-prime wow fadeInUp">
                        <!-- Satisfy Client Images Start -->
                        <div class="satisfy-client-images">
                            <div class="satisfy-client-image">
                                <figure class="image-anime">
                                    <img src="/images/author-1.jpg" alt="Клиент AI агентства">
                                </figure>
                            </div>
                            <div class="satisfy-client-image">
                                <figure class="image-anime">
                                    <img src="/images/author-2.jpg" alt="Клиент AI агентства">
                                </figure>
                            </div>
                            <div class="satisfy-client-image">
                                <figure class="image-anime">
                                    <img src="/images/author-3.jpg" alt="Клиент AI агентства">
                                </figure>
                            </div>
                            <div class="satisfy-client-image">
                                <figure class="image-anime">
                                    <img src="/images/author-4.jpg" alt="Клиент AI агентства">
                                </figure>
                            </div>
                        </div>
                        <!-- Satisfy Client Images End -->

                        <!-- Satisfy Client Content Start -->
                        <div class="hero-satisfy-client-content-prime">
                            <p>Клиенты, которые уже автоматизировали процессы</p>
                        </div>
                        <!-- Satisfy Client Content End -->
                    </div>
                    <!-- Hero Sub Heading End -->

                    <!-- Section Title Start -->
                    <div class="section-title">
                        <h1 class="wow fadeInUp" data-wow-delay="0.2s" data-cursor="-opaque">AI инженер автоматизация бизнеса</h1>
                        <p class="wow fadeInUp" data-wow-delay="0.4s">Разработка AI-агентов, автоматизация CRM и создание MVP. Сокращаю расходы бизнеса до 70% за счет внедрения нейросетей.</p>
                    </div>
                    <!-- Section Title End -->

                    <!-- Hero Content Counter Box Start -->
                    <div class="hero-content-counter-box-prime">
                        <!-- Hero Counter Box Start -->
                        <div class="hero-counter-box-prime">
                            <h2><span class="counter">95</span>%</h2>
                            <p>Уровень удовлетворенности</p>
                        </div>
                        <!-- Hero Counter Box End -->

                        <!-- Hero Counter Box Start -->
                        <div class="hero-counter-box-prime">
                            <h2><span class="counter">12</span>+ лет</h2>
                            <p>Опыта в разработке и автоматизации</p>
                        </div>
                        <!-- Hero Counter Box End -->

                        <!-- Hero Counter Box Start -->
                        <div class="hero-counter-box-prime">
                            <h2><span class="counter">250</span>+</h2>
                            <p>Реализованных проектов</p>
                        </div>
                        <!-- Hero Counter Box End -->
                    </div>
                    <!-- Hero Content Counter Box End -->

                    <!-- Hero Footer Start -->
                    <div class="hero-footer-prime wow fadeInUp" data-wow-delay="0.2s">
                        <!-- Hero Button Start -->
                        <div class="hero-btn-prime">
                            <a href={import.meta.env.PUBLIC_TELEGRAM_URL || "https://t.me/W1DO_DIGITAL"} class="btn-default" data-cursor="-opaque">Начать автоматизацию</a>
                        </div>
                        <!-- Hero Button End -->

                        <!-- Google Rating Box Start -->
                        <div class="google-rating-box-prime">
                            <div class="google-rating-info-prime">
                                <div class="google-rating-info-header-prime">
                                    <h2><span class="counter">4.9</span>/5</h2>
                                    <span class="google-rating-star-prime"><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i></span>
                                </div>
                                <div class="google-rating-info-content-prime">
                                    <p>Более 100 положительных отзывов на фриланс-биржах</p>
                                </div>
                            </div>
                        </div>
                        <!-- Google Rating Box End -->
                    </div>
                    <!-- Hero Footer End -->
                </div>
                <!-- Hero Content Box End -->
            </div>
        </div>
    </div>
</div>
<!-- Hero Section End -->
