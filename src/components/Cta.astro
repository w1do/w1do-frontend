---
interface Props {
    subTitle?: string;
    title?: string;
    description?: string;
    formTitle?: string;
}

const {
    subTitle = "Свяжитесь со мной сегодня",
    title = "Готовы автоматизировать свой бизнес?",
    description = "Оставьте заявку, и я проведу бесплатный аудит ваших задач, чтобы предложить лучшие AI-решения, которые сэкономят ваше время и деньги.",
    formTitle = "Оставить заявку"
} = Astro.props;
---
<!-- Cta Box Section Start -->
<div class="cta-box bg-section">
    <div class="container">
        <div class="row">
            <div class="col-xl-6">
                <!-- Cta Box Content Start -->
                <div class="cta-box-content">
                    <!-- Section Title Start -->
                    <div class="section-title section-title-center">
                        <span class="section-sub-title wow fadeInUp">{subTitle}</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                        <p class="wow fadeInUp" data-wow-delay="0.2s">{description}</p>
                    </div>
                    <!-- Section Title End -->

                    <!-- Cta Button Start -->
                    <div class="cta-btn wow fadeInUp" data-wow-delay="0.4s">
                        <a href={import.meta.env.PUBLIC_TELEGRAM_URL} class="btn-default">Написать в Telegram</a>
                    </div>
                    <!-- Cta Button End -->
                </div>
                <!-- Cta Box Content End -->
            </div>

            <div class="col-xl-6">
                <!-- Cta Contact Box Start -->
                <div class="cta-form-box box-border-gradiant">
                    <!-- Section Title Start -->
                    <div class="section-title section-title-center">
                        <h2 class="text-anime-style-3" data-cursor="-opaque">Связаться напрямую</h2>
                        <p class="wow fadeInUp" data-wow-delay="0.2s">Выберите удобный способ связи для быстрого обсуждения вашего проекта.</p>
                    </div>
                    <!-- Section Title End -->

                    <div class="cta-contact-cards wow fadeInUp" data-wow-delay="0.4s">
                        <!-- Telegram Card -->
                        <div class="cta-contact-card mb-4">
                            <a href={import.meta.env.PUBLIC_TELEGRAM_URL} class="btn-default w-100 d-flex align-items-center justify-content-center">
                                <i class="fa-brands fa-telegram me-2"></i> Написать в Telegram
                            </a>
                        </div>
                        
                        <!-- Max Card -->
                        <div class="cta-contact-card">
                            <a href={import.meta.env.PUBLIC_MAX_URL} class="btn-default w-100 d-flex align-items-center justify-content-center" style="background: var(--primary-color); border-color: var(--primary-color);">
                                <i class="fa-solid fa-link me-2"></i> Связаться через Max
                            </a>
                        </div>
                    </div>
                </div>
                <!-- Cta Contact Box End -->
            </div>
        </div>
    </div>
</div>

<style>
    .cta-contact-cards {
        margin-top: 30px;
    }
    .w-100 {
        width: 100%;
    }
</style>
<!-- Cta Box Section End -->