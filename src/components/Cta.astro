---
interface Props {
    subTitle?: string;
    title?: string;
    description?: string;
    formTitle?: string;
}

const {
    subTitle = "Свяжитесь со мной сегодня",
    title = "Готовы автоматизировать свой бизнес?",
    description = "Оставьте заявку, и я проведу бесплатный аудит ваших задач, чтобы предложить лучшие AI-решения, которые сэкономят ваше время и деньги.",
    formTitle = "Оставить заявку"
} = Astro.props;
---
<!-- Cta Box Section Start -->
<div class="cta-box bg-section">
    <div class="container">
        <div class="row">
            <div class="col-xl-6">
                <!-- Cta Box Content Start -->
                <div class="cta-box-content">
                    <!-- Section Title Start -->
                    <div class="section-title section-title-center">
                        <span class="section-sub-title wow fadeInUp">{subTitle}</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                        <p class="wow fadeInUp" data-wow-delay="0.2s">{description}</p>
                    </div>
                    <!-- Section Title End -->

                    <!-- Cta Button Start -->
                    <div class="cta-btn wow fadeInUp" data-wow-delay="0.4s">
                        <a href={import.meta.env.PUBLIC_TELEGRAM_URL} class="btn-default">Написать в Telegram</a>
                    </div>
                    <!-- Cta Button End -->
                </div>
                <!-- Cta Box Content End -->
            </div>

            <div class="col-xl-6">
                <!-- Cta Form Box Start -->
                <div class="cta-form-box box-border-gradiant">
                    <!-- Section Title Start -->
                    <div class="section-title section-title-center">
                        <h2 class="text-anime-style-3" data-cursor="-opaque">{formTitle}</h2>
                    </div>
                    <!-- Section Title End -->

                    <!-- Cta Form Start -->
                    <div class="contact-form">
                        <form id="contactForm" action="#" method="POST" data-toggle="validator" class="contact-form wow fadeInUp" data-wow-delay="0.2s">
                            <div class="row">
                                <div class="form-group col-md-6 mb-4">
                                    <label>Имя *</label>
                                    <input type="text" name="fname" class="form-control" id="fname" placeholder="Введите имя *" required="">
                                    <div class="help-block with-errors"></div>
                                </div>

                                <div class="form-group col-md-6 mb-4">
                                    <label>Телефон / Telegram *</label>
                                    <input type="text" name="phone" class="form-control" id="phone" placeholder="Введите номер или ник *" required="">
                                    <div class="help-block with-errors"></div>
                                </div>

                                <div class="form-group col-md-12 mb-4">
                                    <label>Email Address *</label>
                                    <input type="email" name="email" class="form-control" id="email" placeholder="Введите email *" required="">
                                    <div class="help-block with-errors"></div>
                                </div>

                                <div class="form-group col-md-12 mb-5">
                                    <label>Описание задачи *</label>
                                    <textarea name="message" class="form-control" id="message" rows="5" placeholder="Расскажите кратко о вашей задаче..."></textarea>
                                    <div class="help-block with-errors"></div>
                                </div>

                                <div class="col-md-12">
                                    <button type="submit" id="submitBtn" class="btn-default">Отправить заявку</button>
                                    <div id="msgSubmit" class="h3 hidden"></div>
                                </div>
                            </div>
                        </form>
                    </div>
                    <!-- Cta Form End -->
                </div>
                <!-- Cta Form Box End -->
            </div>
        </div>
    </div>
</div>

<script>
    const contactForm = document.getElementById('contactForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const msgSubmit = document.getElementById('msgSubmit');

    if (contactForm) {
        contactForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData(contactForm);
            const data = {
                fname: formData.get('fname'),
                phone: formData.get('phone'),
                email: formData.get('email'),
                message: formData.get('message'),
            };

            // Disable button
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerText = 'Отправка...';
            }

            try {
                console.log('Sending request to /api/send-telegram...');
                const response = await fetch('/api/send-telegram', {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        ...data,
                        source: 'CTA Form'
                    }),
                });
                console.log('Response status:', response.status);

                if (response.ok) {
                    if (msgSubmit) {
                        msgSubmit.innerText = 'Заявка успешно отправлена!';
                        msgSubmit.classList.remove('hidden', 'text-danger');
                        msgSubmit.classList.add('text-success');
                    }
                    contactForm.reset();
                } else {
                    const errorData = await response.json();
                    console.error('API Error:', errorData);
                    throw new Error(errorData.message || 'Ошибка при отправке.');
                }
            } catch (error: any) {
                console.error('Error:', error);
                if (msgSubmit) {
                    msgSubmit.innerText = error.message || 'Ошибка при отправке. Попробуйте позже.';
                    msgSubmit.classList.remove('hidden', 'text-success');
                    msgSubmit.classList.add('text-danger');
                }
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerText = 'Отправить заявку';
                }
            }
        });
    }
</script>

<style>
    .hidden {
        display: none;
    }
    .text-success {
        color: #28a745;
        margin-top: 15px;
        font-size: 18px;
    }
    .text-danger {
        color: #dc3545;
        margin-top: 15px;
        font-size: 18px;
    }
</style>
<!-- Cta Box Section End -->