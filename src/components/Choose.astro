---
import { Image } from 'astro:assets';

interface Props {
    subTitle?: string;
    title?: string;
    description?: string;
    benefit1Title?: string;
    benefit1Desc?: string;
    benefit2Title?: string;
    benefit2Desc?: string;
}

const {
    subTitle = "Почему я",
    title = "Почему выбирают внедрение ИИ через меня?",
    description = "Мой главный принцип — окупаемость и прозрачность. Каждый внедренный инструмент должен приносить деньги или экономить время вашего бизнеса.",
    benefit1Title = "Фокус на окупаемости",
    benefit1Desc = "Внедряю только те решения, которые реально оптимизируют расходы или увеличивают прибыль. Никаких хайповых технологий ради технологий.",
    benefit2Title = "Прозрачность и гибкость",
    benefit2Desc = "Вы видите процесс в реальном времени. Работаю как с маленькими стартапами, так и с крупными CRM-системами."
} = Astro.props;
---
<!-- Why Choose Us Section Start -->
<div class="why-choose-us">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-xl-6">
                <!-- Why Choose Image Box Start -->
                <div class="why-choose-image-box wow fadeInUp">
                    <!-- Why Choose Image Box 1 Start -->
                    <div class="why-choose-image-box-1">
                        <!-- Why Choose Image Start -->
                        <div class="why-choose-image">
                            <figure class="image-anime">
                                <Image src="/images/why-choose-image.jpg" alt="Процесс разработки AI решений" width={800} height={800} loading="lazy" />
                            </figure>
                        </div>
                        <!-- Why Choose Image End -->

                        <!-- Contact Us Circle Start -->
                        <div class="contact-us-circle">
                            <a href={import.meta.env.PUBLIC_TELEGRAM_URL || "https://t.me/W1DO_DIGITAL"} data-cursor="-opaque">
                                <img src="/images/contact-us-circle.svg" alt="Связаться со мной">
                            </a>
                        </div>
                        <!-- Contact Us Circle End -->
                    </div>
                    <!-- Why Choose Image Box 1 End -->

                    <!-- Why Choose Image Box 2 Start -->
                    <div class="why-choose-image-box-2">
                        <!-- Why Digital Growth Box Start -->
                        <div class="why-digital-growth-box">
                            <!-- Why Digital Growth Image Start -->
                            <div class="why-digital-growth-image">
                                <figure>
                                    <Image src="/images/why-digital-growth-image.png" alt="График роста эффективности с ИИ" width={100} height={100} loading="lazy" />
                                </figure>
                            </div>
                            <!-- Why Digital Growth Image End -->

                            <!-- Why Digital Growth Body Start -->
                            <div class="why-digital-growth-body">
                                <h3>Цены</h3>
                                <p>Стоимость моих работ всегда ниже рынка, я понимаю рынок спрос, и то что нужно клиенту, я работаю один и не беру сверх доступного бюджета, понимаю бюджет клиента.</p>
                                <h2>от 2 900<sub> р </sub></h2>
                            </div>
                            <!-- Why Digital Growth Body End -->
                        </div>
                        <!-- Why Digital Growth Box End -->
                    </div>
                    <!-- Why Choose Image Box 2 End -->
                </div>
                <!-- Why Choose Image Box End -->
            </div>

            <div class="col-xl-6">
                <!-- Why Choose Content Start -->
                <div class="why-choose-content">
                    <!-- Section Title Start -->
                    <div class="section-title">
                        <span class="section-sub-title wow fadeInUp">{subTitle}</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                        <p class="wow fadeInUp" data-wow-delay="0.2s" set:html={description}></p>
                    </div>
                    <!-- Section Title End -->

                    <!-- Why Choose Item List Start  -->
                    <div class="why-choose-item-list wow fadeInUp" data-wow-delay="0.4s">
                        <!-- Why Choose Item Start -->
                        <div class="why-choose-item box-border-gradiant">
                            <div class="icon-box">
                                <img src="/images/icon-why-choose-item-1.svg" alt={benefit1Title}>
                            </div>
                            <div class="why-choose-item-content">
                                <h3>{benefit1Title}</h3>
                                <p>{benefit1Desc}</p>
                            </div>
                        </div>
                        <!-- Why Choose Item End -->

                        <!-- Why Choose Item Start -->
                        <div class="why-choose-item box-border-gradiant">
                            <div class="icon-box">
                                <img src="/images/icon-why-choose-item-2.svg" alt={benefit2Title}>
                            </div>
                            <div class="why-choose-item-content">
                                <h3>{benefit2Title}</h3>
                                <p>{benefit2Desc}</p>
                            </div>
                        </div>
                        <!-- Why Choose Item End -->
                    </div>
                    <!-- Why Choose Item List End  -->

                    <!-- Why Choose Footer Start -->
                    <div class="why-choose-footer wow fadeInUp" data-wow-delay="0.6s">
                        <!-- Why Choose Button Start -->
                        <div class="why-choose-btn">
                            <a href={import.meta.env.PUBLIC_TELEGRAM_URL || "https://t.me/W1DO_DIGITAL"} class="btn-default" data-cursor="-opaque">Telegram</a>
                        </div>
                        <!-- Why Choose Button End -->

                        <!-- Section Footer Text Start -->
                        <div class="section-footer-text section-satisfy-img">
                            <!-- Satisfy Client Images Start -->
                            <div class="satisfy-client-images">
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-1.jpg" alt="Довольный клиент">
                                    </figure>
                                </div>
                                <div class="satisfy-client-image add-more">
                                    <img src="/images/icon-phone-black.svg" alt="Телефон">
                                </div>
                            </div>
                            <!-- Satisfy Client Images End -->
                            <p>Обсудить детали проекта <a href={import.meta.env.PUBLIC_TELEGRAM_URL || "https://t.me/W1DO_DIGITAL"} data-cursor="-opaque"> написать</a></p>
                        </div>
                        <!-- Section Footer Text End -->
                    </div>
                    <!-- Why Choose Footer End -->
                </div>
                <!-- Why Choose Content End -->
            </div>
        </div>
    </div>
</div>
<!-- Why Choose Us Section End -->