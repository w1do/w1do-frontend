---
import { getCollection } from 'astro:content';
import ProjectCard from "./ProjectCard.astro";
const projects = await getCollection('case');
---

<!-- Page Projects Start -->
<div class="page-projects">
    <div class="container">
        <div class="row">
            {projects.map((project: any, index: number) => (
                <ProjectCard 
                    project={project} 
                    delay={`${(index % 3) * 0.2}s`}
                />
            ))}
        </div>
    </div>
</div>
<!-- Page Projects End -->