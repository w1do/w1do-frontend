---
import ProjectCard from "./ProjectCard.astro";
const projects = Object.values(import.meta.glob('../../pages/case/*.md', { eager: true }));

const featuredProjects = projects.slice(0, 3);
---

<!-- Our Project Section Start -->
<div class="our-projects bg-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <!-- Project Filter Box Header Start -->
                <div class="project-filter-box-header">
                    <!-- Section Title Start -->
                    <div class="section-title">
                        <span class="section-sub-title wow fadeInUp">Мои проекты</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">Воплощаю идеи в мощные цифровые решения</h2>
                    </div>
                    <!-- Section Title End -->

                    <!-- Our Project Nav start -->
                    <div class="our-project-filter-nav wow fadeInUp" data-wow-delay="0.2s">
                        <ul>
                            <li><a href="#" class="active-btn" data-filter="*"><img src="/images/icon-our-feature-tab-1.svg" alt="Все проекты"> Все проекты</a></li>
                            <li><a href="#" data-filter=".seo"><img src="/images/icon-our-feature-tab-1.svg" alt="SEO & Content"> SEO & Content</a></li>
                            <li><a href="#" data-filter=".uiux"><img src="/images/icon-our-feature-tab-1.svg" alt="AI Решения"> AI Решения</a></li>
                            <li><a href="#" data-filter=".web"><img src="/images/icon-our-feature-tab-1.svg" alt="AI Автоматизация"> AI Автоматизация</a></li>
                        </ul>
                    </div>
                    <!-- Our Project Nav End -->
                </div>
                <!-- Project Filter Box Header End -->
            </div>
            <!-- Project Item List end -->
        </div>
        <!-- Our Project Tab Box End -->

        <div class="row project-item-list">
            {featuredProjects.map((project: any, index: number) => (
                <ProjectCard 
                    project={project} 
                    delay={`${index * 0.2}s`}
                />
            ))}
        </div>

        <div class="row">
            <div class="col-lg-12">
                <!-- Section Footer Text Start -->
                <div class="section-footer-text section-satisfy-img wow fadeInUp" data-wow-delay="0.4s">
                    <!-- Satisfy Client Images Start -->
                    <div class="satisfy-client-images">
                        <div class="satisfy-client-image">
                            <figure class="image-anime">
                                <img src="/images/author-1.jpg" alt="Довольный клиент">
                            </figure>
                        </div>
                        <div class="satisfy-client-image add-more">
                            <img src="/images/icon-phone-black.svg" alt="Телефон">
                        </div>
                    </div>
                    <!-- Satisfy Client Images End -->
                    <p>Давайте создадим что-то великое вместе. <a href="/case">Посмотреть все проекты.</a></p>
                </div>
                <!-- Section Footer Text End -->
            </div>
        </div>
    </div>
</div>
<!-- Our Project Section End -->