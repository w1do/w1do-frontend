---
interface PricingItem {
    title: string;
    price: string;
    description: string;
    features: string[];
    icon?: string;
}

interface Props {
    subTitle?: string;
    title?: string;
    description?: string;
    pricingItems?: PricingItem[];
}

const {
    subTitle = "Тарифные планы",
    title = "Выберите подходящий вариант для вашего бизнеса",
    description = "Гибкие условия сотрудничества, адаптированные под масштаб и задачи вашего проекта. От простых интеграций до разработки сложных экосистем.",
    pricingItems = [
        {
            title: "Автоматизация",
            price: "от 750 ₽/час",
            description: "Оптимально для настройки готовых решений и работы с API.",
            features: ["Интеграция сторонних API", "Автоматизация рутинных задач", "Настройка Make / Zapier"],
            icon: "/images/icon-pricing-1.svg"
        },
        {
            title: "Разработка",
            price: "от 1 100 ₽/час",
            description: "Разработка кастомных AI-агентов на базе Claude и GPT под ключ.",
            features: ["Кастомные AI-агенты (Claude)", "Разработка промпт-инженерных систем", "Создание MVP продукта"],
            icon: "/images/icon-pricing-2.svg"
        },
        {
            title: "Сложные решения",
            price: "от 1 800 ₽/час",
            description: "Архитектурные решения с поддержкой и масштабированием.",
            features: ["RAG-системы для бизнеса", "Приоритетная поддержка", "Масштабируемая инфраструктура"],
            icon: "/images/icon-pricing-3.svg"
        }
    ]
} = Astro.props;
---
<!-- Our Pricing Plan Section Start -->
<div class="our-pricing-prime">
    <div class="container">
        <div class="row section-row">
            <div class="col-lg-12">
                <!-- Section Title Start -->
                <div class="section-title section-title-center">
                    <span class="section-sub-title wow fadeInUp">{subTitle}</span>
                    <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                    <p class="wow fadeInUp" data-wow-delay="0.2s">{description}</p>
                </div>
                <!-- Section Title End -->
            </div>
        </div>

        <div class="row pricing-items-list">
            {pricingItems.map((item, index) => (
                <div class="col-xl-4 col-md-6">
                    <!-- Pricing Item Start -->
                    <div class="pricing-item box-border-gradiant wow fadeInUp" data-wow-delay={`${index * 0.2}s`}>
                        <!-- Pricing Item Header Start -->
                        <div class="pricing-item-header">
                            <div class="icon-box">
                                <img src={item.icon || `/images/icon-pricing-${index + 1}.svg`} alt={item.title}>
                            </div>
                            <div class="pricing-item-header-title">
                                <h2>{item.title}</h2>
                            </div>
                        </div>
                        <!-- Pricing Item Header End -->

                        <!-- Pricing Item Price Start -->
                        <div class="pricing-item-price">
                            <h2>{item.price}</h2>
                            <p>{item.description}</p>
                        </div>
                        <!-- Pricing Item Price End -->

                        <!-- Pricing Item Button Start -->
                        <div class="pricing-item-btn">
                            <a href={import.meta.env.PUBLIC_TELEGRAM_URL || "https://t.me/W1DO_DIGITAL"} class="btn-default" data-cursor="-opaque">Обсудить проект</a>
                        </div>
                        <!-- Pricing Item Button End -->

                        <!-- Pricing Item List Start -->
                        <div class="pricing-item-list">
                            <h3>Что включено:</h3>
                            <ul>
                                {item.features.map((feature) => (
                                    <li>{feature}</li>
                                ))}
                            </ul>
                        </div>
                        <!-- Pricing Item List End -->
                    </div>
                    <!-- Pricing Item End -->
                </div>
            ))}

            <div class="col-lg-12">
                <!-- Pricing Benifit List Start -->
                <div class="pricing-benefit-list wow fadeInUp" data-wow-delay="0.6s">
                    <ul>
                        <li><img src="/images/icon-pricing-benefit-1.svg" alt="Гарантия">Бесплатная консультация</li>
                        <li><img src="/images/icon-pricing-benefit-2.svg" alt="Прозрачность">Никаких скрытых платежей</li>
                        <li><img src="/images/icon-pricing-benefit-3.svg" alt="Гибкость">Гибкое управление задачами</li>
                    </ul>
                </div>
                <!-- Pricing Benifit List End -->
            </div>
        </div>
    </div>
</div>
<!-- Our Pricing Plan Section Start -->