---
interface Props {
    subTitle?: string;
    title?: string;
    description?: string;
    step1Title?: string;
    step1Desc?: string;
    step2Title?: string;
    step2Desc?: string;
    step3Title?: string;
    step3Desc?: string;
    step4Title?: string;
    step4Desc?: string;
}

const {
    subTitle = "Процесс работы",
    title = "AI Roadmap: как я внедряю нейросети в ваш бизнес",
    description = "Этот процесс позволяет мне создавать высококачественные цифровые решения, которые помогают бизнесу расти и достигать реальных результатов.",
    step1Title = "Анализ",
    step1Desc = "Изучаю ваши бизнес-процессы и нахожу точки роста",
    step2Title = "Прототип",
    step2Desc = "Создаю минимально рабочий ИИ-инструмент для теста",
    step3Title = "Масштабирование",
    step3Desc = "Полноценная интеграция в ваши системы",
    step4Title = "Поддержка",
    step4Desc = "Постоянная оптимизация алгоритмов под задачи"
} = Astro.props;
---
<!-- Our Process Section Start -->
<div class="our-process">
    <div class="container">
        <div class="row section-row align-items-center">
            <div class="col-xl-6">
                <!-- Section Title Start -->
                <div class="section-title">
                    <span class="section-sub-title wow fadeInUp">{subTitle}</span>
                    <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                </div>
                <!-- Section Title End -->
            </div>

            <div class="col-xl-6">
                <!-- Section Content Button Start -->
                <div class="section-content-btn">
                    <!-- Section Title Content Start -->
                    <div class="section-title-content wow fadeInUp" data-wow-delay="0.2s">
                        <p>{description}</p>
                    </div>
                    <!-- Section Title Content End -->

                    <!-- Section Button Start -->
                    <div class="section-btn wow fadeInUp" data-wow-delay="0.4s">
                        <a href={import.meta.env.PUBLIC_TELEGRAM_URL || "https://t.me/W1DO_DIGITAL"} class="btn-default" data-cursor="-opaque">Связаться</a>
                    </div>
                    <!-- Section Button End -->
                </div>
                <!-- Section Content Button End -->
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <!-- Process Item List Start -->
                <div class="process-item-list">
                    <!-- Process Item Start -->
                    <div class="process-item box-border-gradiant wow fadeInUp">
                        <div class="icon-box">
                            <img src="/images/icon-process-item-1.svg" alt={step1Title}>
                        </div>
                        <div class="process-item-content">
                            <p>{step1Title}</p>
                            <h3>{step1Desc}</h3>
                        </div>
                        <div class="process-item-no">
                            <h3>.01</h3>
                        </div>
                    </div>
                    <!-- Process Item End -->

                    <!-- Process Item Start -->
                    <div class="process-item box-border-gradiant wow fadeInUp" data-wow-delay="0.2s">
                        <div class="icon-box">
                            <img src="/images/icon-process-item-2.svg" alt={step2Title}>
                        </div>
                        <div class="process-item-content">
                            <p>{step2Title}</p>
                            <h3>{step2Desc}</h3>
                        </div>
                        <div class="process-item-no">
                            <h3>.02</h3>
                        </div>
                    </div>
                    <!-- Process Item End -->

                    <!-- Process Item Start -->
                    <div class="process-item box-border-gradiant wow fadeInUp" data-wow-delay="0.4s">
                        <div class="icon-box">
                            <img src="/images/icon-process-item-3.svg" alt={step3Title}>
                        </div>
                        <div class="process-item-content">
                            <p>{step3Title}</p>
                            <h3>{step3Desc}</h3>
                        </div>
                        <div class="process-item-no">
                            <h3>.03</h3>
                        </div>
                    </div>
                    <!-- Process Item End -->

                    <!-- Process Item Start -->
                    <div class="process-item box-border-gradiant wow fadeInUp" data-wow-delay="0.6s">
                        <div class="icon-box">
                            <img src="/images/icon-process-item-4.svg" alt={step4Title}>
                        </div>
                        <div class="process-item-content">
                            <p>{step4Title}</p>
                            <h3>{step4Desc}</h3>
                        </div>
                        <div class="process-item-no">
                            <h3>.04</h3>
                        </div>
                    </div>
                    <!-- Process Item End -->
                </div>
                <!-- Process Item List End -->
            </div>

            <div class="col-lg-12">
                <!-- Section Footer Text Start -->
                <div class="section-footer-text wow fadeInUp" data-wow-delay="0.2s">
                    <p>Помогаю брендам подключаться, расти и достигать успеха в современном цифровом мире</p>
                    <ul class="section-footer-border-list">
                        <li>Доверяют более <b>100+</b> клиентов</li>
                        <li>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <b><span class="counter">4.9</span>/5</b>
                        </li>
                    </ul>
                </div>
                <!-- Section Footer Text End -->
            </div>
        </div>
    </div>
</div>
<!-- Our Process Section End -->