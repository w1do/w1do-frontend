---
interface Props {
    title?: string;
    breadcrumbItems?: { label: string; href?: string; active?: boolean }[];
}

const { 
    title = "Мои услуги",
    breadcrumbItems = [
        { label: "Главная", href: "/" },
        { label: "Мои услуги", active: true }
    ] 
} = Astro.props;
---
<!-- Page Header Start -->
<div class="page-header parallaxie">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <!-- Page Header Box Start -->
                <div class="page-header-box">
                    <h1 class="text-anime-style-3" data-cursor="-opaque">{title}</h1>
                    <nav class="wow fadeInUp">
                        <ol class="breadcrumb">
                            {breadcrumbItems.map((item) => (
                                <li class={`breadcrumb-item ${item.active ? 'active' : ''}`} aria-current={item.active ? "page" : undefined}>
                                    {item.active ? item.label : <a href={item.href}>{item.label}</a>}
                                </li>
                            ))}
                        </ol>
                    </nav>
                </div>
                <!-- Page Header Box End -->
            </div>
        </div>
    </div>
</div>
<!-- Page Header End -->