---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const latestPosts = posts
    .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
    .slice(0, 3);
---
<!-- Our Blog Section Start -->
<div class="our-blog">
    <div class="container">
        <div class="row section-row align-items-center">
            <div class="col-xl-6">
                <!-- Section Title Start -->
                <div class="section-title">
                    <span class="section-sub-title wow fadeInUp">Блог</span>
                    <h2 class="text-anime-style-3" data-cursor="-opaque">Инсайты, кейсы и тренды из мира искусственного интеллекта</h2>
                </div>
                <!-- Section Title End -->
            </div>

            <div class="col-xl-6">
                <!-- Section Content Button Start -->
                <div class="section-content-btn">
                    <!-- Section Title Content Start -->
                    <div class="section-title-content wow fadeInUp" data-wow-delay="0.2s">
                        <p>Оставайтесь в курсе последних достижений в области ИИ, практических советов по внедрению нейросетей и автоматизации бизнес-процессов.</p>
                    </div>
                    <!-- Section Title Content End -->

                    <!-- Section Button Start -->
                    <div class="section-btn wow fadeInUp" data-wow-delay="0.4s">
                        <a href="/blog" class="btn-default">Все статьи</a>
                    </div>
                    <!-- Section Button End -->
                </div>
                <!-- Section Content Button End -->
            </div>
        </div>

        <div class="row post-item-list">
            {latestPosts.map((post, index) => (
                <div class="col-xl-4 col-md-6">
                    <!-- Post Item Start -->
                    <div class:list={["post-item", "box-border-gradiant", "wow", "fadeInUp", index === 0 && "active"]} data-wow-delay={`${index * 0.2}s`}>
                        <!-- Post Item image Start -->
                        <div class="post-item-image">
                            <figure>
                                <img src={post.data.image || "/images/post-1.jpg"} alt={post.data.title} width="600" height="400" loading="lazy" />
                            </figure>
                        </div>
                        <!-- Post Item image End -->

                        <!-- Post Item Button Start -->
                        <div class="post-item-btn">
                            <a href={`/blog/${post.id}`}><img src="/images/arrow-primary.svg" alt="Перейти к статье"></a>
                        </div>
                        <!-- Post Item Button End -->

                        <!-- Post Item Body Start -->
                        <div class="post-item-body">
                            <!-- Post Item Content Start -->
                            <div class="post-item-content">
                                <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
                            </div>
                            <!-- Post Item Content End -->

                            <!-- Post Item Meta Start -->
                            <div class="post-item-meta">
                                <ul>
                                    <li>
                                        <img src="/images/icon-calendar-date.svg" alt="Дата">
                                        {new Date(post.data.pubDate).toLocaleDateString('ru-RU', {
                                            year: 'numeric',
                                            month: 'long',
                                            day: 'numeric'
                                        })}
                                    </li>
                                </ul>
                            </div>
                            <!-- Post Item Meta End -->
                        </div>
                        <!-- Post Item Body End -->
                    </div>
                    <!-- Post Item End -->
                </div>
            ))}
        </div>
    </div>
</div>
<!-- Our Blog Section End -->
