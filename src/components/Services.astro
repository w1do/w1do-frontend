---
import { getCollection } from 'astro:content';
import ServicesList from "./services/ServicesList.astro";

interface Props {
    subTitle?: string;
    title?: string;
    description?: string;
    limit?: number;
}

const {
    subTitle = "Услуги по внедрению AI В бизнес, Claude, Junie",
    title = "Услуги по разработке и автоматизации с помощью ИИ",
    description = "От разработки стратегии до ее реализации я сосредоточен на достижении значимых результатов, которые способствуют расширению вашего бизнеса и его долгосрочному успеху.",
    limit = 6
} = Astro.props;

const entries = await getCollection('services');
const services = entries.map((entry) => ({
    ...entry.data,
    link: `/services/${entry.id}`,
    delay: `${(parseInt(entry.data.no || "1") - 1) * 0.2}s`
})).sort((a, b) => (a.no || "").localeCompare(b.no || ""));

const featuredServices = services.slice(0, limit);
---

<!-- Our Service Section Start -->
<div class="our-services bg-section">
    <div class="container">
        <div class="row">
            <div class="col-xl-6">
                <!-- Our Service Content Start -->
                <div class="our-service-content">
                    <!-- Section Title Start -->
                    <div class="section-title">
                        <span class="section-sub-title wow fadeInUp">{subTitle}</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                        <p class="wow fadeInUp" data-wow-delay="0.2s">{description}</p>
                    </div>
                    <!-- Section Title Start -->

                    <!-- Our Service Button Start -->
                    <div class="our-service-btn wow fadeInUp" data-wow-delay="0.4s">
                        <a href="/services" class="btn-default">Все услуги</a>
                    </div>
                    <!-- Our Service Button End -->
                </div>
                <!-- Our Service Content End -->
            </div>

            <div class="col-xl-6">
                <ServicesList services={featuredServices} />
            </div>
        </div>
    </div>
</div>
<!-- Our Service Section End -->