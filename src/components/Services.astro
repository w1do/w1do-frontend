---
import ServicesList from "./services/ServicesList.astro";
import { services } from "../mocks/services";

const featuredServices = services.slice(0, 6);
---

<!-- Our Service Section Start -->
<div class="our-services bg-section">
    <div class="container">
        <div class="row">
            <div class="col-xl-6">
                <!-- Our Service Content Start -->
                <div class="our-service-content">
                    <!-- Section Title Start -->
                    <div class="section-title">
                        <span class="section-sub-title wow fadeInUp">Мои услуги</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">Услуги по разработке и автоматизации с помощью ИИ</h2>
                        <p class="wow fadeInUp" data-wow-delay="0.2s">От разработки стратегии до ее реализации я сосредоточен на достижении значимых результатов, которые способствуют расширению вашего бизнеса и его долгосрочному успеху.</p>
                    </div>
                    <!-- Section Title Start -->

                    <!-- Our Service Button Start -->
                    <div class="our-service-btn wow fadeInUp" data-wow-delay="0.4s">
                        <a href="/services" class="btn-default">Все услуги</a>
                    </div>
                    <!-- Our Service Button End -->
                </div>
                <!-- Our Service Content End -->
            </div>

            <div class="col-xl-6">
                <ServicesList services={featuredServices} />
            </div>
        </div>
    </div>
</div>
<!-- Our Service Section End -->