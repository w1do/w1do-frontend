---
interface AwardItem {
    icon: string;
    title: string;
    description: string;
    year: string;
}

interface Props {
    subTitle?: string;
    title?: string;
    description?: string;
    counterValue?: string;
    counterDesc?: string;
    awards?: AwardItem[];
    sliderText?: string;
    showSocialLinks?: boolean;
}

const {
    subTitle = "Опыт и практика",
    title = "Как я использовал LLM в своих задачах",
    description = "Каждая модель была подобрана под конкретную бизнес-задачу для достижения максимальной эффективности.",
    counterValue = "500",
    counterDesc = "Часов проектирования промптов и интеграций.",
    awards = [
        {
            icon: '/images/llm/gemini-color.svg',
            title: 'Gemini Nano',
            description: 'Создал сервис для автоподбора дизайна ногтей на базе генерации изображений.',
            year: '2025'
        },
        {
            icon: '/images/llm/claude-color.svg',
            title: 'Claude 4.7/4.8 Sonnet',
            description: 'Автономный агент для e-commerce: обработка возвратов и поддержка клиентов.',
            year: '2025'
        },
        {
            icon: '/images/llm/deepseek-color.svg',
            title: 'DeepSeek V3',
            description: 'AI-анализ юр. документов: поиск коллизий и автоматическое составление протоколов.',
            year: '2026'
        }
    ],
    sliderText = "Использую лучшие технологии индустрии",
    showSocialLinks = false
} = Astro.props;
---
<!-- Our Awards Section Start -->
<div class='our-awards-prime bg-section'>
    <div class='container'>
        <div class='row'>
            <div class='col-xl-6'>
                <!-- Awards Item Content Start -->
                <div class='awards-content-prime'>
                    <!-- Section Title Start -->
                    <div class='section-title'>
                        <span class='section-sub-title wow fadeInUp'>{subTitle}</span>
                        <h2 class='text-anime-style-3' data-cursor='-opaque'>{title}</h2>
                        <p class='wow fadeInUp' data-wow-delay='0.2s'>{description}</p>
                    </div>
                    <!-- Section Title End -->

                    <!-- Awards Item Counter Box Start -->
                    <div class='awards-counter-box-prime wow fadeInUp'>
                        <h2><span class='counter'>{counterValue}</span>+</h2>
                        <p>{counterDesc}</p>
                    </div>
                    <!-- Awards Item Counter Box End -->

                    {showSocialLinks && (
                        <div class="section-btn wow fadeInUp" data-wow-delay="0.4s" style="margin-top: 30px; text-align: left;">
                            <a href="https://www.youtube.com/@w1do_digital" class="btn-default" target="_blank" rel="noopener noreferrer" style="margin-right: 15px; margin-left: 0;">YouTube Канал</a>
                            <a href="https://t.me/w1do_tech" class="btn-default" target="_blank" rel="noopener noreferrer" style="margin-left: 0;">Telegram Канал</a>
                        </div>
                    )}
                </div>
                <!-- Awards Item Content End -->
            </div>

            <div class='col-xl-6'>
                <!-- Awards Item List Start -->
                <div class='awards-item-list-prime box-border-gradiant'>
                    {awards.map((award, index) => (
                        <div class='awards-item-prime wow fadeInUp' data-wow-delay={index > 0 ? `${index * 0.2}s` : undefined}>
                            <div class='awards-item-body-prime'>
                                <div class='icon-box'>
                                    <img src={award.icon} alt={award.title} style='width: 80px; height: 80px; filter: brightness(0) invert(1);'>
                                </div>
                                <div class='awards-item-content-prime'>
                                    <h3>{award.title}</h3>
                                    <p>{award.description}</p>
                                </div>
                            </div>
                            <div class='awards-item-year-prime'>
                                <h3>{award.year}</h3>
                            </div>
                        </div>
                    ))}
                </div>
                <!-- Awards Item List End -->
            </div>

            <div class='col-lg-12'>
                <!-- Comapany Support Slider Start -->
                <div class='company-supports-slider-box-prime'>
                    <!-- Comapany Support Content Start -->
                    <div class='company-supports-content-prime'>
                        <hr>
                        <p>{sliderText}</p>
                        <hr>
                    </div>
                    <!-- Comapany Support Content End -->

                    <!-- Comapany Support Slider Start -->
                    <div class='company-supports-slider-prime'>
                        <div class='swiper'>
                            <div class='swiper-wrapper'>
                                <!-- Company Support Logo Start -->
                                <div class='swiper-slide'>
                                    <div class='company-supports-logo-prime'>
                                        <img src='/images/company-supports-logo-1-prime.svg' alt='' loading='lazy' style='filter: brightness(0) invert(1);'>
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class='swiper-slide'>
                                    <div class='company-supports-logo-prime'>
                                        <img src='/images/company-supports-logo-2-prime.svg' alt='' loading='lazy' style='filter: brightness(0) invert(1);'>
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class='swiper-slide'>
                                    <div class='company-supports-logo-prime'>
                                        <img src='/images/company-supports-logo-3-prime.svg' alt='' loading='lazy' style='filter: brightness(0) invert(1);'>
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class='swiper-slide'>
                                    <div class='company-supports-logo-prime'>
                                        <img src='/images/company-supports-logo-4-prime.svg' alt='' loading='lazy' style='filter: brightness(0) invert(1);'>
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class='swiper-slide'>
                                    <div class='company-supports-logo-prime'>
                                        <img src='/images/company-supports-logo-3-prime.svg' alt='' loading='lazy' style='filter: brightness(0) invert(1);'>
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class='swiper-slide'>
                                    <div class='company-supports-logo-prime'>
                                        <img src='/images/company-supports-logo-5-prime.svg' alt='' loading='lazy' style='filter: brightness(0) invert(1);'>
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class='swiper-slide'>
                                    <div class='company-supports-logo-prime'>
                                        <img src='/images/company-supports-logo-2-prime.svg' alt='' loading='lazy' style='filter: brightness(0) invert(1);'>
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->
                            </div>
                        </div>
                    </div>
                    <!-- Comapany Support Slider End -->
                </div>
                <!-- Comapany Support Slider End -->
            </div>
        </div>
    </div>
</div>
<!-- Our Awards Section End -->

<style>
    .awards-item-year-prime h3 {
        font-size: 32px !important;
    }
</style>