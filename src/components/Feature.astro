---
import { Image } from 'astro:assets';

interface Props {
    subTitle?: string;
    title?: string;
    description?: string;
}

const {
    subTitle = "Технологии",
    title = "Стек, который дает результат",
    description = "Я использую связку <strong>Cursor + Claude</strong>, что позволяет мне писать код в 4 руки, минимизируя ошибки и ускоряя деплой ваших проектов в разы."
} = Astro.props;
---
<!-- Core Feature Section Start -->
<div class="core-feature">
    <div class="container">
        <div class="row section-row align-items-center">
            <div class="col-xl-6">
                <!-- Section Title Start -->
                <div class="section-title">
                    <span class="section-sub-title wow fadeInUp">{subTitle}</span>
                    <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                </div>
                <!-- Section Title End -->
            </div>

            <div class="col-xl-6">
                <!-- Section Content Button Start -->
                <div class="section-content-btn">
                    <!-- Section Title Content Start -->
                    <div class="section-title-content wow fadeInUp" data-wow-delay="0.2s">
                        <p set:html={description}></p>
                    </div>
                    <!-- Section Title Content End -->

                    <!-- Section Button Start -->
                    <div class="section-btn wow fadeInUp" data-wow-delay="0.4s">
                        <a href={import.meta.env.PUBLIC_TELEGRAM_URL} class="btn-default">Связаться</a>
                    </div>
                    <!-- Section Button End -->
                </div>
                <!-- Section Content Button End -->
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <!-- Core Feature List Box Start -->
                <div class="core-feature-list-box">
                    <!-- Core Feature Box Start -->
                    <div class="core-feature-box box-1 box-border-gradiant wow fadeInUp">
                        <div class="core-feature-image">
                            <figure>
                                <Image src="/images/core-feature-image-1.png" alt="Технологический стек AI инженера" width={500} height={400} loading="lazy" />
                            </figure>
                        </div>
                        <div class="core-feature-body-content">
                            <h2>Сложные интеграции</h2>
                            <p>Чат-боты, ассистенты и любые системы на базе LLM для автоматизации вашего бизнеса.</p>
                        </div>
                    </div>
                    <!-- Core Feature Box End -->

                    <!-- Core Feature Box Start -->
                    <div class="core-feature-box box-2 wow fadeInUp" data-wow-delay="0.2s">
                        <!-- Core Feature Image Start -->
                        <div class="core-feature-image">
                            <figure>
                                <Image src="/images/core-feature-image.jpg" alt="Инженер за работой над AI проектом" width={800} height={600} loading="lazy" />
                            </figure>
                        </div>
                        <!-- Core Feature Image End -->
                    </div>
                    <!-- Core Feature Box End -->

                    <!-- Core Feature Box Start -->
                    <div class="core-feature-box box-3 box-border-gradiant wow fadeInUp" data-wow-delay="0.4s">
                        <div class="icon-box">
                            <img src="/images/icon-core-feature-1.svg" alt="Иконка опыта">
                        </div>
                        <div class="core-feature-body-content">
                            <h2><span class="counter">12</span>+ лет опыта</h2>
                            <p>Знаю, как подружить существующий код с новыми нейросетями и создавать стабильные высоконагруженные системы.</p>
                            <ul>
                                <li>Экспертиза в индустрии</li>
                            </ul>
                        </div>
                    </div>
                    <!-- Core Feature Box End -->

                    <!-- Core Feature Box Start -->
                    <div class="core-feature-box box-4 wow fadeInUp" data-wow-delay="0.6s">
                        <!-- Core Feature Cta Review Box Start -->
                        <div class="core-feature-cta-review-box">
                            <!-- Satisfy Client images Start -->
                            <div class="satisfy-client-images">
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-2.jpg" alt="Клиент AI инженера">
                                    </figure>
                                </div>
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-1.jpg" alt="Клиент AI инженера">
                                    </figure>
                                </div>
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-3.jpg" alt="Клиент AI инженера">
                                    </figure>
                                </div>
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-4.jpg" alt="Клиент AI инженера">
                                    </figure>
                                </div>
                            </div>
                            <!-- Satisfy Client images End -->

                            <!-- Google Rating Box Start -->
                            <div class="google-rating-box">
                                <div class="google-rating-logo">
                                    <img src="/images/icon-google.svg" alt="Google Logo">
                                </div>
                                <div class="google-rating-info">
                                    <div class="google-rating-info-header">
                                        <h2><span class="counter">4.9</span>/5</h2>
                                        <span class="google-rating-star"><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i></span>
                                    </div>
                                    <p>Более 100+ отзывов на фрилансе</p>
                                </div>
                            </div>
                            <!-- Google Rating Box Start -->
                        </div>
                        <!-- Core Feature Cta Review Box End -->

                        <!-- Core Feature Review Content Start -->
                        <div class="core-feature-review-content">
                            <p>“ Решения которые я создаю, помогают и облечают рутинные задачи, и освобождают время для более важдых дел ”</p>
                        </div>
                        <!-- Core Feature Review Content End -->
                    </div>
                    <!-- Core Feature Box Start -->

                    <!-- Core Feature Box Start -->
                    <div class="core-feature-box box-5 wow fadeInUp" data-wow-delay="0.8s">
                        <!-- Core Feature Contact Item Start -->
                        <div class="core-feature-contact-item">
                            <div class="icon-box">
                                <img src="/images/icon-headphone-white.svg" alt="Связь со мной">
                            </div>
                            <div class="core-feature-title">
                                <h2>Нужна помощь?</h2>
                            </div>
                        </div>
                        <!-- Core Feature Contact Item End -->

                        <!-- Core Feature Contact Content Start -->
                        <div class="core-feature-contact-content">
                            <p>У вас есть проект или вам нужна консультация эксперта ?</p>
                        </div>
                        <!-- Core Feature Contact Content End -->
                    </div>
                    <!-- Core Feature Box Start -->
                </div>
                <!-- Core Feature List Box End -->
            </div>
        </div>
    </div>
</div>
<!-- Core Feature Section End -->