---
interface Props {
    subTitle?: string;
    title?: string;
    description?: string;
    counterValue?: string;
    counterTag?: string;
    counterDescription?: string;
}

const {
    subTitle = "О разработчике",
    title = "Разработка ИИ",
    description = "Я создаю ИИ-решения, которые автоматизируют ваш бизнес. Использую стек: <strong>Python</strong>, <strong>Claude</strong>, <strong>Cursor</strong> и <strong>Junie</strong> для ускорения разработки в 5 раз. Мой опыт позволяет внедрять системы, которые реально работают на ваш доход.",
    counterValue = "100",
    counterTag = "ИИ-проектов",
    counterDescription = "автоматизация процессов и внедрение LLM"
} = Astro.props;
---
<!-- About Us Section Start -->
<div class="about-us">
    <div class="container">
        <div class="row">
            <div class="col-xl-4">
                <!-- About Sub Heading Start -->
                <div class="about-sub-heading">
                    <!-- Section Sub Heading Start -->
                    <div class="section-sub-heading">
                        <span class="section-sub-title wow fadeInUp">{subTitle}</span>
                    </div>
                    <!-- Section Sub Heading End -->
                </div>
                <!-- About Sub Heading End -->
            </div>

            <div class="col-xl-8">
                <!-- About Us Content Start -->
                <div class="about-us-content">
                    <!-- Section Title Start -->
                    <div class="section-title">
                        <h2 class="text-effect">{title}</h2>
                    </div>
                    <!-- Section Title End -->

                    <!-- About Us Body Start -->
                    <div class="about-us-body">
                        <!-- About Counter Box start -->
                        <div class="about-counter-box wow fadeInUp">
                            <div class="about-counter-box-header">
                                <h2><span class="counter">{counterValue}</span>+</h2>
                                <span class="about-counter-tag">{counterTag}</span>
                            </div>
                            <div class="about-counter-box-body">
                                <p>{counterDescription}</p>
                            </div>
                        </div>
                        <!-- About Counter Box End -->

                        <!-- About Body Content Start -->
                        <div class="about-body-content-box wow fadeInUp" data-wow-delay="0.2s">
                            <!-- About Body Content Start -->
                            <div class="about-body-content">
                                <p set:html={description}></p>
                            </div>
                            <!-- About Body Content End -->

                            <!-- About Body Review Box Start -->
                            <div class="about-body-review-box">
                                <!-- Contact Us Circle Start -->
                                <div class="contact-us-circle">
                                    <a href={import.meta.env.PUBLIC_TELEGRAM_URL || "https://t.me/W1DO_DIGITAL"} data-cursor="-opaque">
                                        <img src="/images/contact-us-circle-transparent.svg" alt="Связаться со мной">
                                    </a>
                                </div>
                                <!-- Contact Us Circle End -->

                                <!-- About Client Box Start -->
                                <div class="about-client-box">
                                    <!-- Satisfy Client Images Start -->
                                    <div class="satisfy-client-images">
                                        <div class="satisfy-client-image">
                                            <figure class="image-anime">
                                                <img src="/images/author-1.jpg" alt="Разработчик ИИ проверяет работу нейросети" loading="lazy">
                                            </figure>
                                        </div>
                                        <div class="satisfy-client-image">
                                            <figure class="image-anime">
                                                <img src="/images/author-2.jpg" alt="Пример внедрения ИИ в бизнес" loading="lazy">
                                            </figure>
                                        </div>
                                        <div class="satisfy-client-image">
                                            <figure class="image-anime">
                                                <img src="/images/author-3.jpg" alt="Автоматизация с помощью ИИ-агентов" loading="lazy">
                                            </figure>
                                        </div>
                                        <div class="satisfy-client-image">
                                            <figure class="image-anime">
                                                <img src="/images/author-4.jpg" alt="Интеграция LLM моделей в CRM" loading="lazy">
                                            </figure>
                                        </div>
                                    </div>
                                    <!-- Satisfy Client Images End -->

                                    <!-- Google Rating Box Start -->
                                    <div class="google-rating-box">
                                        <div class="google-rating-logo">
                                            <img src="/images/icon-google.svg" alt="Отзывы W1DO DIGITAL">
                                        </div>
                                        <div class="google-rating-info">
                                            <div class="google-rating-info-header">
                                                <h2><span class="counter">4.9</span>/5</h2>
                                                <span class="google-rating-star"><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i><i class="fa fa-solid fa-star"></i></span>
                                            </div>
                                            <p>Более 100 отзывов на фриланс площадках</p>
                                        </div>
                                    </div>
                                    <!-- Google Rating Box Start -->
                                </div>
                                <!-- About Client Box End -->
                            </div>
                            <!-- About Body Review Box End -->
                        </div>
                        <!-- About Body Content End -->
                    </div>
                    <!-- About Us Body End -->
                </div>
                <!-- About Us Content End -->
            </div>

            <div class="col-lg-12">
                <!-- Company Supports Slider Box Start -->
                <div class="company-supports-slider-box">
                    <!-- Company Supports Content Start -->
                    <div class="company-supports-content">
                        <hr>
                        <p>Инструменты с которыми я работаю</p>
                        <hr>
                    </div>
                    <!-- Company Supports Content End -->

                    <!-- Company Supports Slider Start -->
                    <div class="company-supports-slider">
                        <div class="swiper">
                            <div class="swiper-wrapper">
                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/claude-color.svg" alt="Claude AI">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/gemini-color.svg" alt="Google Gemini">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/openai.svg" alt="OpenAI">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/cursor.svg" alt="Cursor AI">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/deepseek-color.svg" alt="DeepSeek">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/mistral-color.svg" alt="Mistral AI">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/n8n-color.svg" alt="n8n Automation">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/huggingface-color.svg" alt="Hugging Face">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/ollama.svg" alt="Ollama">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/aistudio.svg" alt="Google AI Studio">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/anthropic.svg" alt="Anthropic">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/openrouter.svg" alt="OpenRouter">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/qwen-color.svg" alt="Qwen">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->

                                <!-- Company Support Logo Start -->
                                <div class="swiper-slide">
                                    <div class="company-supports-logo">
                                        <img src="/images/llm/grok.svg" alt="Grok">
                                    </div>
                                </div>
                                <!-- Comapany Support Logo End -->
                            </div>
                        </div>
                    </div>
                    <!-- Company Supports Slider End -->
                </div>
                <!-- Company Supports Slider Box End -->
            </div>
        </div>
    </div>
</div>
<!-- About Us Section End -->

<style>
    .company-supports-logo img {
        filter: brightness(0) invert(1);
        opacity: 0.7;
        transition: opacity 0.3s ease;
    }
    .company-supports-logo img:hover {
        opacity: 1;
    }
</style>